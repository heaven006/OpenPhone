+        private static void readWatchersLocked(Cursor cursor, JSONArray watchers) {
+            while (cursor.moveToNext()) {
+                final JSONObject watcher = new JSONObject();
+                try {
+                    watcher.put("id", cursor.getLong(0));
+                    watcher.put("type", cursor.getString(1));
+                    watcher.put("title", cursor.getString(2));
+                    watcher.put("condition_json", cursor.getString(3));
+                    watcher.put("schedule_json", cursor.getString(4));
+                    watcher.put("session_target", cursor.getString(5));
+                    watcher.put("delivery_json", cursor.getString(6));
+                    watcher.put("status", cursor.getString(7));
+                    watcher.put("created_at", cursor.getLong(8));
+                    watcher.put("updated_at", cursor.getLong(9));
+                    watcher.put("next_run_at", cursor.getLong(10));
+                    watcher.put("running_at", cursor.getLong(11));
+                    watcher.put("last_run_at", cursor.getLong(12));
+                    watcher.put("last_result_hash", cursor.getString(13));
+                    watcher.put("failure_count", cursor.getInt(14));
