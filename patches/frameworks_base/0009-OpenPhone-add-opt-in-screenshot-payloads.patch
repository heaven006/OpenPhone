+        private ScreenPayload captureScreenPayload(String requestJson) {
+            final JSONObject request = parseJsonObject(requestJson);
+            if (!request.optBoolean("include_screenshot", false)) {
+                return ScreenPayload.none();
+            }
+            final int maxDimension = Math.max(160, Math.min(1080,
+                    request.optInt("max_dimension", DEFAULT_SCREENSHOT_MAX_DIMENSION)));
+            final int quality = Math.max(30, Math.min(90,
+                    request.optInt("quality", DEFAULT_SCREENSHOT_QUALITY)));
+            final WindowManagerInternal windowManager = LocalServices.getService(
+                    WindowManagerInternal.class);
+            if (windowManager == null) {
+                return ScreenPayload.error("window_manager_unavailable");
+            }
+            final ScreenshotHardwareBuffer hardwareBuffer = windowManager.takeAssistScreenshot();
+            if (hardwareBuffer == null || hardwareBuffer.getHardwareBuffer() == null) {
+                return ScreenPayload.error("capture_failed");
+            }
+            if (hardwareBuffer.containsSecureLayers()) {
+                return ScreenPayload.error("secure_layers_present");
+            }
+            final Bitmap hardwareBitmap = hardwareBuffer.asBitmap();
+            if (hardwareBitmap == null) {
+                return ScreenPayload.error("bitmap_unavailable");
+            }
+            Bitmap bitmap = null;
+            Bitmap scaledBitmap = null;
+            try {
+                bitmap = hardwareBitmap.copy(Bitmap.Config.ARGB_8888, false);
+                if (bitmap == null) {
+                    return ScreenPayload.error("bitmap_copy_failed");
+                }
+                scaledBitmap = scaleBitmap(bitmap, maxDimension);
+                final ByteArrayOutputStream output = new ByteArrayOutputStream();
+                if (!scaledBitmap.compress(Bitmap.CompressFormat.JPEG, quality, output)) {
+                    return ScreenPayload.error("jpeg_encode_failed");
+                }
+                return ScreenPayload.jpegBase64(scaledBitmap.getWidth(), scaledBitmap.getHeight(),
+                        quality, Base64.encodeToString(output.toByteArray(), Base64.NO_WRAP));
+            } finally {
+                if (scaledBitmap != null && scaledBitmap != bitmap) {
+                    scaledBitmap.recycle();
+                }
+                if (bitmap != null) {
+                    bitmap.recycle();
+                }
+                hardwareBitmap.recycle();
+            }
+        }
+
+        private static Bitmap scaleBitmap(Bitmap bitmap, int maxDimension) {
+            final int width = bitmap.getWidth();
+            final int height = bitmap.getHeight();
+            final int longest = Math.max(width, height);
+            if (longest <= maxDimension) {
+                return bitmap;
+            }
+            final float scale = (float) maxDimension / (float) longest;
+            final int targetWidth = Math.max(1, Math.round(width * scale));
+            final int targetHeight = Math.max(1, Math.round(height * scale));
+            return Bitmap.createScaledBitmap(bitmap, targetWidth, targetHeight, true);
+        }
+
+        private static JSONObject parseJsonObject(String rawJson) {
+            if (rawJson == null || rawJson.isEmpty()) {
+                return new JSONObject();
+            }
+            try {
+                return new JSONObject(rawJson);
+            } catch (JSONException e) {
+                return new JSONObject();
+            }
+        }
+
