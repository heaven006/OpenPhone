diff --git a/services/core/java/com/android/server/openphone/OpenPhoneAssistantDataService.java b/services/core/java/com/android/server/openphone/OpenPhoneAssistantDataService.java
new file mode 100644
index 000000000000..0b99175f5b93
--- /dev/null
+++ b/services/core/java/com/android/server/openphone/OpenPhoneAssistantDataService.java
@@ -0,0 +1,1024 @@
+/*
+ * Copyright 2026 OpenPhone contributors.
+ *
+ * SPDX-License-Identifier: PolyForm-Noncommercial-1.0.0
+ *
+ * Commercial use requires a separate written license.
+ */
+
+package com.android.server.openphone;
+
+import android.content.ContentValues;
+import android.content.Context;
+import android.database.Cursor;
+import android.database.sqlite.SQLiteDatabase;
+import android.openphone.IOpenPhoneAssistantDataService;
+import android.os.Binder;
+import android.os.Environment;
+import android.util.Slog;
+
+import com.android.server.SystemService;
+
+import org.json.JSONArray;
+import org.json.JSONException;
+import org.json.JSONObject;
+
+import java.io.File;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Locale;
+
+/**
+ * OS-owned durable store for the assistant's memories, commitments and
+ * watchers. Owns the canonical tables under /data/system/openphone/ so this
+ * user data survives assistant reinstalls and can later serve more than one
+ * client surface.
+ */
+public final class OpenPhoneAssistantDataService extends SystemService {
+    private static final String TAG = "OpenPhoneAssistantData";
+    private static final String PERMISSION_USE_ASSISTANT_DATA =
+            "org.openphone.permission.USE_ASSISTANT_DATA";
+    private static final String OPENPHONE_SYSTEM_DIR = "openphone";
+    private static final String DB_FILE = "assistant_data.db";
+    private static final int SCHEMA_VERSION = 1;
+    private static final int MAX_LIMIT = 100;
+
+    private final BinderService mBinderService;
+
+    public OpenPhoneAssistantDataService(Context context) {
+        super(context);
+        mBinderService = new BinderService(context);
+    }
+
+    @Override
+    public void onStart() {
+        publishBinderService(Context.OPENPHONE_ASSISTANT_DATA_SERVICE, mBinderService);
+        Slog.i(TAG, "OpenPhone assistant data service published");
+    }
+
+    private static final class BinderService extends IOpenPhoneAssistantDataService.Stub {
+        private final Context mContext;
+        private final Object mDbLock = new Object();
+        private SQLiteDatabase mDb;
+
+        BinderService(Context context) {
+            mContext = context;
+        }
+
+        @Override
+        public String getServiceStatus() {
+            enforcePermission();
+            long memories = -1L;
+            long commitments = -1L;
+            long watchers = -1L;
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    memories = countLocked(db, "memory");
+                    commitments = countLocked(db, "commitment");
+                    watchers = countLocked(db, "watcher");
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "status query failed", e);
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("state", "ready");
+                json.put("service", Context.OPENPHONE_ASSISTANT_DATA_SERVICE);
+                json.put("schema_version", SCHEMA_VERSION);
+                json.put("memory_count", memories);
+                json.put("commitment_count", commitments);
+                json.put("watcher_count", watchers);
+                json.put("source", "system_server.openphone_assistant_data");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        // ---------------------------------------------------------------
+        // Memory
+        // ---------------------------------------------------------------
+
+        @Override
+        public String memorySave(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String text = request.optString("text", "").trim();
+            if (text.isEmpty()) {
+                return errorJson("missing_text");
+            }
+            final long now = System.currentTimeMillis();
+            final String normalized = normalize(text);
+            final ContentValues values = new ContentValues();
+            values.put("type", safe(request.optString("type", ""), "fact"));
+            values.put("subject", safe(request.optString("subject", ""), "user"));
+            values.put("text", text);
+            values.put("normalized_text", normalized);
+            values.put("confidence", clampConfidence(request.optDouble("confidence", 1.0)));
+            values.put("status", "active");
+            values.put("evidence_json", safeJson(request.optString("evidence_json", "")));
+            values.put("created_at", now);
+            values.put("updated_at", now);
+            values.put("source_uid", Binder.getCallingUid());
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    long id = db.insertWithOnConflict("memory", null, values,
+                            SQLiteDatabase.CONFLICT_IGNORE);
+                    if (id < 0) {
+                        final ContentValues update = new ContentValues(values);
+                        update.remove("normalized_text");
+                        update.remove("created_at");
+                        db.update("memory", update, "normalized_text = ?",
+                                new String[]{normalized});
+                        id = idForNormalizedTextLocked(db, normalized);
+                    }
+                    return idJson(id);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "memorySave failed", e);
+                    return errorJson("save_failed");
+                }
+            }
+        }
+
+        @Override
+        public String memoryQuery(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String query = request.optString("query", "").trim();
+            final int limit = boundLimit(request.optInt("limit", 20));
+            final JSONArray memories = new JSONArray();
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    boolean done = false;
+                    if (!query.isEmpty()) {
+                        final String ftsQuery = query.replace('"', ' ').trim();
+                        try (Cursor cursor = db.rawQuery("SELECT m.id, m.type, m.subject, "
+                                + "m.text, m.confidence, m.created_at, m.updated_at, "
+                                + "m.evidence_json "
+                                + "FROM memory_fts f JOIN memory m ON m.id = f.rowid "
+                                + "WHERE memory_fts MATCH ? AND m.status = 'active' "
+                                + "AND m.deleted_at IS NULL "
+                                + "ORDER BY m.updated_at DESC LIMIT ?",
+                                new String[]{ftsQuery, Integer.toString(limit)})) {
+                            readMemoriesLocked(cursor, memories);
+                            done = true;
+                        } catch (RuntimeException e) {
+                            // Malformed FTS query: fall through to the latest scan.
+                        }
+                    }
+                    if (!done) {
+                        try (Cursor cursor = db.rawQuery("SELECT id, type, subject, text, "
+                                + "confidence, created_at, updated_at, evidence_json "
+                                + "FROM memory WHERE status = 'active' AND deleted_at IS NULL "
+                                + "ORDER BY updated_at DESC LIMIT ?",
+                                new String[]{Integer.toString(limit)})) {
+                            readMemoriesLocked(cursor, memories);
+                        }
+                    }
+                    touchMemoriesLocked(db, memories);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "memoryQuery failed", e);
+                    return errorJson("query_failed");
+                }
+            }
+            return wrapArray("memories", memories);
+        }
+
+        private static void readMemoriesLocked(Cursor cursor, JSONArray memories) {
+            while (cursor.moveToNext()) {
+                final JSONObject memory = new JSONObject();
+                try {
+                    memory.put("id", cursor.getLong(0));
+                    memory.put("type", cursor.getString(1));
+                    memory.put("subject", cursor.getString(2));
+                    memory.put("text", cursor.getString(3));
+                    memory.put("confidence", cursor.getFloat(4));
+                    memory.put("created_at", cursor.getLong(5));
+                    memory.put("updated_at", cursor.getLong(6));
+                    memory.put("evidence_json", cursor.getString(7));
+                } catch (JSONException e) {
+                    continue;
+                }
+                memories.put(memory);
+            }
+        }
+
+        private static void touchMemoriesLocked(SQLiteDatabase db, JSONArray memories) {
+            if (memories.length() == 0) {
+                return;
+            }
+            final ContentValues values = new ContentValues();
+            values.put("last_used_at", System.currentTimeMillis());
+            for (int i = 0; i < memories.length(); i++) {
+                final JSONObject memory = memories.optJSONObject(i);
+                if (memory == null) {
+                    continue;
+                }
+                db.update("memory", values, "id = ?",
+                        new String[]{Long.toString(memory.optLong("id"))});
+            }
+        }
+
+        private static long idForNormalizedTextLocked(SQLiteDatabase db, String normalized) {
+            try (Cursor cursor = db.rawQuery("SELECT id FROM memory WHERE normalized_text = ?",
+                    new String[]{normalized})) {
+                return cursor.moveToFirst() ? cursor.getLong(0) : -1L;
+            }
+        }
+
+        // ---------------------------------------------------------------
+        // Commitments
+        // ---------------------------------------------------------------
+
+        @Override
+        public String commitmentCreate(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String title = request.optString("title", "").trim();
+            if (title.isEmpty()) {
+                return errorJson("missing_title");
+            }
+            final long now = System.currentTimeMillis();
+            final ContentValues values = new ContentValues();
+            values.put("title", title);
+            values.put("description", request.optString("description", "").trim());
+            values.put("normalized_title", normalize(title));
+            values.put("trigger_type", safe(request.optString("trigger_type", ""), "manual"));
+            values.put("trigger_spec_json", safeJson(request.optString("trigger_spec_json", "")));
+            values.put("due_at", request.optLong("due_at", 0L));
+            values.put("expires_at", request.optLong("expires_at", 0L));
+            values.put("status", "pending");
+            values.put("confidence", clampConfidence(request.optDouble("confidence", 1.0)));
+            values.put("evidence_json", safeJson(request.optString("evidence_json", "")));
+            values.put("created_at", now);
+            values.put("updated_at", now);
+            values.put("source_uid", Binder.getCallingUid());
+            synchronized (mDbLock) {
+                try {
+                    return idJson(openLocked().insert("commitment", null, values));
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "commitmentCreate failed", e);
+                    return errorJson("create_failed");
+                }
+            }
+        }
+
+        @Override
+        public String commitmentUpdate(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final long id = request.optLong("id", 0L);
+            final String action = request.optString("action", "").trim();
+            if (id <= 0 || action.isEmpty()) {
+                return errorJson("invalid_request");
+            }
+            final long now = System.currentTimeMillis();
+            final ContentValues values = new ContentValues();
+            switch (action) {
+                case "status":
+                    final String status = request.optString("status", "").trim();
+                    if (status.isEmpty()) {
+                        return errorJson("missing_status");
+                    }
+                    values.put("status", status);
+                    values.put("updated_at", now);
+                    break;
+                case "snooze":
+                    final long dueAt = request.optLong("due_at", 0L);
+                    if (dueAt <= 0) {
+                        return errorJson("missing_due_at");
+                    }
+                    values.put("status", "snoozed");
+                    values.put("due_at", dueAt);
+                    values.put("updated_at", now);
+                    break;
+                case "dismiss":
+                    values.put("status", "dismissed");
+                    values.put("updated_at", now);
+                    values.put("deleted_at", now);
+                    break;
+                default:
+                    return errorJson("unknown_action");
+            }
+            synchronized (mDbLock) {
+                try {
+                    final int updated = openLocked().update("commitment", values, "id = ?",
+                            new String[]{Long.toString(id)});
+                    return updatedJson(updated > 0);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "commitmentUpdate failed", e);
+                    return errorJson("update_failed");
+                }
+            }
+        }
+
+        @Override
+        public String commitmentQuery(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String mode = request.optString("mode", "active").trim();
+            final long now = request.optLong("now", System.currentTimeMillis());
+            final int limit = boundLimit(request.optInt("limit", 20));
+            final String commitmentColumns = "id, title, description, trigger_type, "
+                    + "trigger_spec_json, due_at, expires_at, status, confidence, "
+                    + "evidence_json, created_at, updated_at";
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    if ("next_due_at".equals(mode)) {
+                        long nextDueAt = 0L;
+                        try (Cursor cursor = db.rawQuery("SELECT due_at FROM commitment "
+                                + "WHERE status IN ('pending','active','snoozed') "
+                                + "AND deleted_at IS NULL AND due_at > ? "
+                                + "ORDER BY due_at ASC LIMIT 1",
+                                new String[]{Long.toString(now)})) {
+                            if (cursor.moveToFirst()) {
+                                nextDueAt = cursor.getLong(0);
+                            }
+                        }
+                        return new JSONObject().put("next_due_at", nextDueAt).toString();
+                    }
+                    final JSONArray commitments = new JSONArray();
+                    if ("due".equals(mode)) {
+                        try (Cursor cursor = db.rawQuery("SELECT " + commitmentColumns
+                                + " FROM commitment "
+                                + "WHERE status IN ('pending','active','snoozed') "
+                                + "AND deleted_at IS NULL AND due_at > 0 AND due_at <= ? "
+                                + "ORDER BY due_at ASC LIMIT ?",
+                                new String[]{Long.toString(now), Integer.toString(limit)})) {
+                            readCommitmentsLocked(cursor, commitments);
+                        }
+                        return wrapArray("commitments", commitments);
+                    }
+                    if ("search".equals(mode)) {
+                        final String query = request.optString("query", "").trim();
+                        if (!query.isEmpty()) {
+                            final String ftsQuery = query.replace('"', ' ').trim();
+                            try (Cursor cursor = db.rawQuery("SELECT c.id, c.title, "
+                                    + "c.description, c.trigger_type, c.trigger_spec_json, "
+                                    + "c.due_at, c.expires_at, c.status, c.confidence, "
+                                    + "c.evidence_json, c.created_at, c.updated_at "
+                                    + "FROM commitment_fts f "
+                                    + "JOIN commitment c ON c.id = f.rowid "
+                                    + "WHERE commitment_fts MATCH ? AND c.deleted_at IS NULL "
+                                    + "ORDER BY c.updated_at DESC LIMIT ?",
+                                    new String[]{ftsQuery, Integer.toString(limit)})) {
+                                readCommitmentsLocked(cursor, commitments);
+                                return wrapArray("commitments", commitments);
+                            } catch (RuntimeException e) {
+                                // Malformed FTS query: fall through to active.
+                            }
+                        }
+                    }
+                    try (Cursor cursor = db.rawQuery("SELECT " + commitmentColumns
+                            + " FROM commitment "
+                            + "WHERE status IN ('pending','active','snoozed') "
+                            + "AND deleted_at IS NULL "
+                            + "ORDER BY CASE WHEN due_at > 0 THEN due_at "
+                            + "ELSE 9223372036854775807 END ASC, updated_at DESC LIMIT ?",
+                            new String[]{Integer.toString(limit)})) {
+                        readCommitmentsLocked(cursor, commitments);
+                    }
+                    return wrapArray("commitments", commitments);
+                } catch (JSONException e) {
+                    throw new IllegalStateException(e);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "commitmentQuery failed", e);
+                    return errorJson("query_failed");
+                }
+            }
+        }
+
