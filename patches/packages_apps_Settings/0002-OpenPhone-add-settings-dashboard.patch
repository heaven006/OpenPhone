+package com.android.settings.openphone;
+
+import android.app.settings.SettingsEnums;
+
+import com.android.settings.R;
+import com.android.settings.dashboard.DashboardFragment;
+import com.android.settings.search.BaseSearchIndexProvider;
+import com.android.settingslib.search.SearchIndexable;
+
+@SearchIndexable
+public class OpenPhoneSettings extends DashboardFragment {
+    private static final String TAG = "OpenPhoneSettings";
+
+    @Override
+    public int getMetricsCategory() {
+        return SettingsEnums.DASHBOARD_SUMMARY;
+    }
+
+    @Override
+    protected String getLogTag() {
+        return TAG;
+    }
+
+    @Override
+    protected int getPreferenceScreenResId() {
+        return R.xml.openphone_settings;
+    }
+
+    public static final BaseSearchIndexProvider SEARCH_INDEX_DATA_PROVIDER =
+            new BaseSearchIndexProvider(R.xml.openphone_settings);
+}
-- 
