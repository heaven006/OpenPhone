+            }
             return "unknown";
         }
 
@@ -622,7 +709,9 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             }
             if ("input.perform".equals(capabilityId)
                     || "settings.write".equals(capabilityId)
-                    || "notifications.act".equals(capabilityId)) {
+                    || "notifications.act".equals(capabilityId)
+                    || "clipboard.read".equals(capabilityId)
+                    || "clipboard.write".equals(capabilityId)) {
                 return "confirmation_required";
             }
             if ("messages.send".equals(capabilityId)
@@ -700,6 +789,20 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             return injectInputEvent(down) && injectInputEvent(up);
         }
 
+        private boolean injectText(String text) {
+            final KeyCharacterMap keyCharacterMap =
+                    KeyCharacterMap.load(KeyCharacterMap.VIRTUAL_KEYBOARD);
+            final KeyEvent[] events = keyCharacterMap.getEvents(text.toCharArray());
+            if (events == null) {
+                return false;
+            }
+            boolean injected = true;
+            for (KeyEvent event : events) {
+                injected &= injectInputEvent(event);
+            }
+            return injected;
+        }
+
         private boolean injectTap(float x, float y, long pressDurationMs) {
             final long downTime = SystemClock.uptimeMillis();
             return injectMotion(MotionEvent.ACTION_DOWN, downTime, downTime, x, y)
