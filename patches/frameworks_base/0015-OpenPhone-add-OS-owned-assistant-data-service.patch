+
+        @Override
+        public String migrateRows(String store, String rowsJsonArray) {
+            enforcePermission();
+            final String table;
+            final String[] columns;
+            switch (store == null ? "" : store) {
+                case "memory":
+                    table = "memory";
+                    columns = new String[]{"type", "subject", "text", "normalized_text",
+                            "confidence", "status", "evidence_json", "created_at",
+                            "updated_at", "last_used_at", "deleted_at"};
+                    break;
+                case "commitment":
+                    table = "commitment";
+                    columns = new String[]{"title", "description", "normalized_title",
+                            "trigger_type", "trigger_spec_json", "due_at", "expires_at",
+                            "status", "confidence", "evidence_json", "created_at",
+                            "updated_at", "last_checked_at", "failure_count", "deleted_at"};
+                    break;
+                case "watcher":
+                    table = "watcher";
+                    columns = new String[]{"type", "title", "condition_json",
+                            "schedule_json", "session_target", "delivery_json", "status",
+                            "created_at", "updated_at", "next_run_at", "running_at",
+                            "last_run_at", "last_result_hash", "failure_count",
+                            "failure_alert_at", "deleted_at"};
+                    break;
+                default:
+                    return errorJson("unknown_store");
+            }
+            final JSONArray rows;
+            try {
+                rows = new JSONArray(rowsJsonArray == null || rowsJsonArray.isEmpty()
+                        ? "[]" : rowsJsonArray);
+            } catch (JSONException e) {
+                return errorJson("invalid_rows_json");
+            }
+            int inserted = 0;
+            int skipped = 0;
+            synchronized (mDbLock) {
+                final SQLiteDatabase db;
+                try {
+                    db = openLocked();
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "migrate open failed", e);
+                    return errorJson("migrate_failed");
+                }
+                db.beginTransaction();
+                try {
+                    for (int i = 0; i < rows.length(); i++) {
+                        final JSONObject row = rows.optJSONObject(i);
+                        if (row == null || row.optLong("id", 0L) <= 0) {
+                            skipped++;
+                            continue;
+                        }
+                        final ContentValues values = new ContentValues();
+                        // Legacy ids are preserved: watcher and commitment ids are
+                        // referenced from alarms and delivered notifications.
+                        values.put("id", row.optLong("id"));
+                        for (String column : columns) {
+                            if (row.isNull(column)) {
+                                values.putNull(column);
+                            } else {
+                                values.put(column, row.optString(column, ""));
+                            }
+                        }
+                        values.put("source_uid", Binder.getCallingUid());
+                        final long id = db.insertWithOnConflict(table, null, values,
+                                SQLiteDatabase.CONFLICT_IGNORE);
+                        if (id > 0) {
+                            inserted++;
+                        } else {
+                            skipped++;
+                        }
+                    }
+                    db.setTransactionSuccessful();
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "migrate failed", e);
+                    return errorJson("migrate_failed");
+                } finally {
+                    db.endTransaction();
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("inserted", inserted);
+                json.put("skipped", skipped);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
