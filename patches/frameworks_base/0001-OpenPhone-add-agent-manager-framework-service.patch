+package com.android.server.openphone;
+
+import android.content.Context;
+import android.openphone.IOpenPhoneAgentService;
+import android.os.Binder;
+import android.util.Slog;
+
+import com.android.server.SystemService;
+
+import org.json.JSONException;
+import org.json.JSONObject;
+
+/**
+ * Minimal OpenPhone system_server authority for agent capabilities.
+ */
+public final class OpenPhoneAgentManagerService extends SystemService {
+    private static final String TAG = "OpenPhoneAgentManager";
+    private static final String PERMISSION_READ_SCREEN_CONTEXT =
+            "org.openphone.permission.READ_SCREEN_CONTEXT";
+    private static final String PERMISSION_PERFORM_DEVICE_ACTION =
+            "org.openphone.permission.PERFORM_DEVICE_ACTION";
+    private static final String PERMISSION_MANAGE_AGENT_TASKS =
+            "org.openphone.permission.MANAGE_AGENT_TASKS";
+
+    private final BinderService mBinderService;
+
+    public OpenPhoneAgentManagerService(Context context) {
+        super(context);
+        mBinderService = new BinderService(context);
+    }
+
+    @Override
+    public void onStart() {
+        publishBinderService(Context.OPENPHONE_AGENT_SERVICE, mBinderService);
+        Slog.i(TAG, "OpenPhone agent manager service published");
+    }
+
+    private static final class BinderService extends IOpenPhoneAgentService.Stub {
+        private final Context mContext;
+
+        BinderService(Context context) {
+            mContext = context;
+        }
+
+        @Override
+        public String getServiceStatus() {
+            return statusJson("ready");
+        }
+
+        @Override
+        public String startTask(String taskRequestJson) {
+            enforceManageTasks();
+            return resultJson("task.accepted", taskRequestJson);
+        }
+
+        @Override
+        public String getScreenContext(String taskId) {
+            enforceReadScreenContext();
+            return screenContextJson(taskId);
+        }
+
+        @Override
+        public String executeAction(String taskId, String actionRequestJson) {
+            enforcePerformDeviceAction();
+            return resultJson("action.denied.stub", actionRequestJson);
+        }
+
+        @Override
+        public String evaluateCapability(String capabilityId) {
+            enforceManageTasks();
+            return capabilityJson(capabilityId);
+        }
+
+        private void enforceReadScreenContext() {
+            mContext.enforceCallingOrSelfPermission(
+                    PERMISSION_READ_SCREEN_CONTEXT,
+                    "OpenPhone screen context requires READ_SCREEN_CONTEXT");
+        }
+
+        private void enforcePerformDeviceAction() {
+            mContext.enforceCallingOrSelfPermission(
+                    PERMISSION_PERFORM_DEVICE_ACTION,
+                    "OpenPhone actions require PERFORM_DEVICE_ACTION");
+        }
+
+        private void enforceManageTasks() {
+            mContext.enforceCallingOrSelfPermission(
+                    PERMISSION_MANAGE_AGENT_TASKS,
+                    "OpenPhone task management requires MANAGE_AGENT_TASKS");
+        }
+
+        private static String statusJson(String state) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("state", state);
+                json.put("service", Context.OPENPHONE_AGENT_SERVICE);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private static String screenContextJson(String taskId) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("task_id", taskId);
+                json.put("foreground_app", JSONObject.NULL);
+                json.put("activity", JSONObject.NULL);
+                json.put("visible_text", JSONObject.NULL);
+                json.put("interactive_elements", JSONObject.NULL);
+                json.put("risk_flags", JSONObject.NULL);
+                json.put("source", "system_server.stub");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private static String capabilityJson(String capabilityId) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("capability", capabilityId);
+                json.put("decision", "deny");
+                json.put("reason", "OpenPhone policy backend is not connected yet");
+                json.put("source", "system_server.stub");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private static String resultJson(String state, String inputJson) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("state", state);
+                json.put("caller_uid", Binder.getCallingUid());
+                json.put("input", inputJson);
+                json.put("source", "system_server.stub");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+    }
+}
