+        private String executeNavigationKey(String taskId, String actionRequestJson, String type,
+                String capability) {
+            final int keyCode;
+            switch (type) {
+                case "back":
+                    keyCode = KeyEvent.KEYCODE_BACK;
+                    break;
+                case "home":
+                    keyCode = KeyEvent.KEYCODE_HOME;
+                    break;
+                case "recents":
+                    keyCode = KeyEvent.KEYCODE_APP_SWITCH;
+                    break;
+                default:
+                    return actionResultJson("action.denied.unsupported", taskId, actionRequestJson,
+                            capability, "unsupported_navigation");
+            }
+
+            final boolean injected = injectKey(keyCode);
+            recordAudit(injected ? "action_executed" : "action_rejected", taskId, capability,
+                    injected ? "allow_task_scoped" : "deny", actionRequestJson, type);
+            return actionResultJson(injected ? "action.executed" : "action.denied.input_failed",
+                    taskId, actionRequestJson, capability, type);
+        }
+
+        private String executePointerPress(String taskId, String actionRequestJson,
+                JSONObject request, String capability, boolean longPress) {
+            final JSONObject target = request.optJSONObject("target");
+            final float x = optFloat(target, "x", Float.NaN);
+            final float y = optFloat(target, "y", Float.NaN);
+            if (Float.isNaN(x) || Float.isNaN(y)) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_coordinates");
+                return actionResultJson("action.denied.missing_coordinates", taskId,
+                        actionRequestJson, capability, "missing_coordinates");
+            }
+
+            final boolean injected = injectTap(x, y, longPress ? DEFAULT_LONG_PRESS_MS : 0);
+            final String detail = (longPress ? "long_press" : "tap") + ":" + x + "," + y;
+            recordAudit(injected ? "action_executed" : "action_rejected", taskId, capability,
+                    injected ? "allow_task_scoped" : "deny", actionRequestJson, detail);
+            return actionResultJson(injected ? "action.executed" : "action.denied.input_failed",
+                    taskId, actionRequestJson, capability, detail);
+        }
+
+        private String executeScroll(String taskId, String actionRequestJson, JSONObject request,
+                String capability) {
+            final JSONObject target = request.optJSONObject("target");
+            float startX = optFloat(target, "start_x", Float.NaN);
+            float startY = optFloat(target, "start_y", Float.NaN);
+            float endX = optFloat(target, "end_x", Float.NaN);
+            float endY = optFloat(target, "end_y", Float.NaN);
+            if (Float.isNaN(startX) || Float.isNaN(startY)
+                    || Float.isNaN(endX) || Float.isNaN(endY)) {
+                startX = optFloat(target, "x", Float.NaN);
+                startY = optFloat(target, "y", Float.NaN);
+                final float deltaX = optFloat(target, "dx", 0);
+                final float deltaY = optFloat(target, "dy", 0);
+                endX = Float.isNaN(startX) ? Float.NaN : startX + deltaX;
+                endY = Float.isNaN(startY) ? Float.NaN : startY + deltaY;
+            }
+            if (Float.isNaN(startX) || Float.isNaN(startY)
+                    || Float.isNaN(endX) || Float.isNaN(endY)) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_scroll_coordinates");
+                return actionResultJson("action.denied.missing_coordinates", taskId,
+                        actionRequestJson, capability, "missing_scroll_coordinates");
+            }
+
+            final boolean injected = injectSwipe(startX, startY, endX, endY, DEFAULT_SWIPE_MS);
+            final String detail = "scroll:" + startX + "," + startY + "->" + endX + "," + endY;
+            recordAudit(injected ? "action_executed" : "action_rejected", taskId, capability,
+                    injected ? "allow_task_scoped" : "deny", actionRequestJson, detail);
+            return actionResultJson(injected ? "action.executed" : "action.denied.input_failed",
+                    taskId, actionRequestJson, capability, detail);
+        }
+
+        private String executeTypeText(String taskId, String actionRequestJson, JSONObject request,
+                String capability) {
+            final String text = request.optString("text", "");
+            if (text.isEmpty()) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_text");
+                return actionResultJson("action.denied.missing_text", taskId, actionRequestJson,
+                        capability, "missing_text");
+            }
+
+            final KeyCharacterMap keyCharacterMap =
+                    KeyCharacterMap.load(KeyCharacterMap.VIRTUAL_KEYBOARD);
+            final KeyEvent[] events = keyCharacterMap.getEvents(text.toCharArray());
+            if (events == null) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "text_not_key_mappable");
+                return actionResultJson("action.denied.text_not_key_mappable", taskId,
+                        actionRequestJson, capability, "text_not_key_mappable");
+            }
+
+            boolean injected = true;
+            for (KeyEvent event : events) {
+                injected &= injectInputEvent(event);
+            }
+            recordAudit(injected ? "action_executed" : "action_rejected", taskId, capability,
+                    injected ? "allow_task_scoped" : "deny", actionRequestJson, "type_text");
+            return actionResultJson(injected ? "action.executed" : "action.denied.input_failed",
+                    taskId, actionRequestJson, capability, "type_text");
+        }
