-        private static String resultJson(String state, String inputJson) {
+        private String executeActionInternal(String taskId, String actionRequestJson) {
+            final JSONObject request;
+            try {
+                request = new JSONObject(actionRequestJson);
+            } catch (JSONException e) {
+                recordAudit("action_rejected", taskId, "unknown", "deny",
+                        actionRequestJson, "invalid_json");
+                return actionResultJson("action.denied.invalid_json", taskId, actionRequestJson,
+                        "unknown", "invalid_json");
+            }
+
+            final String type = request.optString("type", "");
+            final String capability = capabilityFromAction(type, request);
+            final String decision = decisionForCapability(capability);
+            if (!"allow_task_scoped".equals(decision)) {
+                recordAudit("action_rejected", taskId, capability, decision,
+                        actionRequestJson, "policy");
+                return actionResultJson("action.confirmation_required".equals(decision)
+                                ? "action.confirmation_required" : "action.denied.policy",
+                        taskId, actionRequestJson, capability, "policy");
+            }
+
+            if ("open_app".equals(type)) {
+                return executeOpenApp(taskId, actionRequestJson, request, capability);
+            }
+
+            recordAudit("action_rejected", taskId, capability, "deny",
+                    actionRequestJson, "unsupported_action");
+            return actionResultJson("action.denied.unsupported", taskId, actionRequestJson,
+                    capability, "unsupported_action");
+        }
+
+        private String executeOpenApp(String taskId, String actionRequestJson, JSONObject request,
+                String capability) {
+            final String packageName = packageNameFromRequest(request);
+            if (packageName == null || packageName.isEmpty()) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_package");
+                return actionResultJson("action.denied.missing_package", taskId, actionRequestJson,
+                        capability, "missing_package");
+            }
+
+            final Intent launchIntent = mContext.getPackageManager()
+                    .getLaunchIntentForPackage(packageName);
+            if (launchIntent == null) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "no_launch_intent");
+                return actionResultJson("action.denied.no_launch_intent", taskId, actionRequestJson,
+                        capability, "no_launch_intent");
+            }
+
+            launchIntent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+            final long token = Binder.clearCallingIdentity();
+            try {
+                mContext.startActivityAsUser(launchIntent, foregroundUser());
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+
+            recordAudit("action_executed", taskId, capability, "allow_task_scoped",
+                    actionRequestJson, packageName);
+            return actionResultJson("action.executed", taskId, actionRequestJson,
+                    capability, packageName);
+        }
+
+        private String actionResultJson(String state, String taskId, String inputJson,
+                String capability, String detail) {
             JSONObject json = new JSONObject();
             try {
                 json.put("state", state);
+                json.put("task_id", taskId);
                 json.put("caller_uid", Binder.getCallingUid());
+                json.put("capability", capability);
+                json.put("detail", detail == null ? JSONObject.NULL : detail);
                 json.put("input", inputJson);
-                json.put("source", "system_server.stub");
+                json.put("source", "system_server.openphone_agent");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private static String taskResultJson(String taskId, String inputJson) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("state", "task.accepted");
+                json.put("task_id", taskId);
+                json.put("caller_uid", Binder.getCallingUid());
+                json.put("input", inputJson);
+                json.put("source", "system_server.openphone_agent");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private List<ActivityAssistInfo> topVisibleActivities() {
+            final ActivityTaskManagerInternal atm =
+                    LocalServices.getService(ActivityTaskManagerInternal.class);
+            if (atm == null) {
+                return new ArrayList<>();
+            }
+            final long token = Binder.clearCallingIdentity();
+            try {
+                final List<ActivityAssistInfo> visibleActivities = atm.getTopVisibleActivities();
+                return visibleActivities == null ? new ArrayList<>() : visibleActivities;
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+        }
+
+        private static JSONArray visibleActivitiesJson(List<ActivityAssistInfo> visibleActivities)
+                throws JSONException {
+            final JSONArray result = new JSONArray();
+            for (int i = 0; i < visibleActivities.size(); i++) {
+                final ActivityAssistInfo activity = visibleActivities.get(i);
+                final ComponentName component = activity.getComponentName();
+                final JSONObject entry = new JSONObject();
+                entry.put("focused", i == 0);
+                entry.put("task_id", activity.getTaskId());
+                entry.put("user_id", activity.getUserId());
+                entry.put("package", component == null
+                        ? JSONObject.NULL : component.getPackageName());
+                entry.put("activity", component == null
+                        ? JSONObject.NULL : component.flattenToShortString());
+                result.put(entry);
+            }
+            return result;
+        }
+
+        private static JSONArray screenContextRiskFlags(List<ActivityAssistInfo> visibleActivities) {
+            final JSONArray flags = new JSONArray();
+            if (visibleActivities.isEmpty()) {
+                flags.put("no_visible_activity");
+            }
+            flags.put("visible_text_unavailable");
+            flags.put("interactive_elements_unavailable");
+            return flags;
+        }
+
+        private UserHandle foregroundUser() {
+            final List<ActivityAssistInfo> visibleActivities = topVisibleActivities();
+            if (!visibleActivities.isEmpty()) {
+                return UserHandle.of(visibleActivities.get(0).getUserId());
+            }
+            return UserHandle.of(ActivityManager.getCurrentUser());
+        }
+
+        private static String packageNameFromRequest(JSONObject request) {
+            final JSONObject target = request.optJSONObject("target");
+            if (target != null) {
+                final String packageName = target.optString("package", "");
+                if (!packageName.isEmpty()) {
+                    return packageName;
+                }
+            }
+            return request.optString("package", "");
+        }
+
+        private static String capabilityFromAction(String type, JSONObject request) {
+            final String declaredCapability = request.optString("capability", "");
+            if (!declaredCapability.isEmpty()) {
+                return declaredCapability;
+            }
+            if ("open_app".equals(type) || "launch_intent".equals(type)) {
+                return "apps.launch";
+            }
+            if ("back".equals(type) || "home".equals(type) || "recents".equals(type)
+                    || "tap".equals(type) || "long_press".equals(type)
+                    || "scroll".equals(type) || "type_text".equals(type)) {
+                return "input.perform";
+            }
+            return "unknown";
+        }
+
+        private static String decisionForCapability(String capabilityId) {
+            if ("screen.read.visible".equals(capabilityId)
+                    || "tasks.observe".equals(capabilityId)
+                    || "apps.launch".equals(capabilityId)) {
+                return "allow_task_scoped";
+            }
+            if ("input.perform".equals(capabilityId)
+                    || "settings.write".equals(capabilityId)
+                    || "notifications.act".equals(capabilityId)) {
+                return "confirmation_required";
+            }
+            if ("messages.send".equals(capabilityId)
+                    || "calls.place".equals(capabilityId)
+                    || "account.access".equals(capabilityId)) {
+                return "explicit_confirmation_required";
+            }
+            return "deny";
+        }
+
+        private static String reasonForCapability(String capabilityId) {
+            final String decision = decisionForCapability(capabilityId);
+            if ("allow_task_scoped".equals(decision)) {
+                return "low-risk OpenPhone seed policy";
+            }
+            if ("confirmation_required".equals(decision)) {
+                return "requires user confirmation; confirmation UI is not connected yet";
+            }
+            if ("explicit_confirmation_required".equals(decision)) {
+                return "high-risk capability requires explicit confirmation";
+            }
+            return "capability is not allowed by the OpenPhone seed policy";
+        }
+
+        private void recordAudit(String eventType, String taskId, String capability,
+                String decision, String inputJson, String detail) {
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("timestamp_elapsed_ms", SystemClock.elapsedRealtime());
+                json.put("event_type", eventType);
+                json.put("task_id", taskId == null ? JSONObject.NULL : taskId);
+                json.put("capability", capability == null ? JSONObject.NULL : capability);
+                json.put("decision", decision == null ? JSONObject.NULL : decision);
+                json.put("caller_uid", Binder.getCallingUid());
+                json.put("detail", detail == null ? JSONObject.NULL : detail);
+                json.put("input_recorded", inputJson != null);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+
+            synchronized (mAuditLock) {
+                while (mAuditEvents.size() >= MAX_AUDIT_EVENTS) {
+                    mAuditEvents.removeFirst();
+                }
+                mAuditEvents.addLast(json.toString());
+            }
+        }
+
+        private int auditSize() {
+            synchronized (mAuditLock) {
+                return mAuditEvents.size();
+            }
+        }
+
+        private String auditLogJson(int maxEvents) {
+            final int boundedMax = maxEvents <= 0 ? 50 : Math.min(maxEvents, MAX_AUDIT_EVENTS);
+            final ArrayList<String> events = new ArrayList<>(boundedMax);
+            synchronized (mAuditLock) {
+                int skipped = Math.max(0, mAuditEvents.size() - boundedMax);
+                int index = 0;
+                for (String event : mAuditEvents) {
+                    if (index++ >= skipped) {
+                        events.add(event);
+                    }
+                }
+            }
+
+            final JSONObject json = new JSONObject();
+            final JSONArray eventJson = new JSONArray();
+            try {
+                for (String event : events) {
+                    eventJson.put(new JSONObject(event));
+                }
+                json.put("events", eventJson);
+                json.put("source", "system_server.openphone_agent");
             } catch (JSONException e) {
                 throw new IllegalStateException(e);
             }
