diff --git a/libselinux/src/avc_internal.c b/libselinux/src/avc_internal.c
index ffc663e5..848dff63 100644
--- a/libselinux/src/avc_internal.c
+++ b/libselinux/src/avc_internal.c
@@ -18,8 +18,10 @@
 #include <poll.h>
 #include <sys/types.h>
 #include <sys/socket.h>
+#if defined(__linux__)
 #include <linux/types.h>
 #include <linux/netlink.h>
+#endif
 #include "callbacks.h"
 #include "selinux_netlink.h"
 #include "avc_internal.h"
@@ -98,6 +100,38 @@ int avc_process_policyload(uint32_t seqno)
 /* netlink socket code */
 static int fd = -1;
 
+#if !defined(__linux__)
+int avc_netlink_open(int blocking __attribute__((unused)))
+{
+	errno = EAFNOSUPPORT;
+	return -1;
+}
+
+void avc_netlink_close(void)
+{
+	fd = -1;
+}
+
+int avc_netlink_check_nb(void)
+{
+	return 0;
+}
+
+void avc_netlink_loop(void)
+{
+}
+
+int avc_netlink_acquire_fd(void)
+{
+	errno = EAFNOSUPPORT;
+	return -1;
+}
+
+void avc_netlink_release_fd(void)
+{
+	avc_app_main_loop = 0;
+}
+#else
 int avc_netlink_open(int blocking)
 {
 	int len, rc = 0;
@@ -321,3 +355,4 @@ void avc_netlink_release_fd(void)
 {
     avc_app_main_loop = 0;
 }
+#endif
diff --git a/libselinux/src/openphone_darwin_compat.h b/libselinux/src/openphone_darwin_compat.h
new file mode 100644
index 00000000..033a9669
--- /dev/null
+++ b/libselinux/src/openphone_darwin_compat.h
@@ -0,0 +1,63 @@
+#pragma once
+
+#if defined(__APPLE__)
+
+#include <sys/xattr.h>
+
+#ifndef O_PATH
+#define O_PATH 0
+#endif
+
+static inline ssize_t openphone_darwin_getxattr4(const char *path, const char *name, void *value,
+						 size_t size)
+{
+	return getxattr(path, name, value, size, 0, 0);
+}
+
+static inline ssize_t openphone_darwin_lgetxattr4(const char *path, const char *name, void *value,
+						  size_t size)
+{
+	return getxattr(path, name, value, size, 0, XATTR_NOFOLLOW);
+}
+
+static inline ssize_t openphone_darwin_fgetxattr4(int fd, const char *name, void *value,
+						  size_t size)
+{
+	return fgetxattr(fd, name, value, size, 0, 0);
+}
+
+static inline int openphone_darwin_setxattr5(const char *path, const char *name,
+					     const void *value, size_t size, int flags)
+{
+	return setxattr(path, name, value, size, 0, flags);
+}
+
+static inline int openphone_darwin_lsetxattr5(const char *path, const char *name,
+					      const void *value, size_t size, int flags)
+{
+	return setxattr(path, name, value, size, 0, flags | XATTR_NOFOLLOW);
+}
+
+static inline int openphone_darwin_fsetxattr5(int fd, const char *name, const void *value,
+					      size_t size, int flags)
+{
+	return fsetxattr(fd, name, value, size, 0, flags);
+}
+
+#define OPENPHONE_DARWIN_SELECT4_OR_6(_1, _2, _3, _4, _5, _6, NAME, ...) NAME
+#define OPENPHONE_DARWIN_SELECT5_OR_6(_1, _2, _3, _4, _5, _6, NAME, ...) NAME
+
+#define getxattr(...) \
+	OPENPHONE_DARWIN_SELECT4_OR_6(__VA_ARGS__, getxattr, getxattr, openphone_darwin_getxattr4)(__VA_ARGS__)
+#define lgetxattr(path, name, value, size) openphone_darwin_lgetxattr4(path, name, value, size)
+#define fgetxattr(...) \
+	OPENPHONE_DARWIN_SELECT4_OR_6(__VA_ARGS__, fgetxattr, fgetxattr, openphone_darwin_fgetxattr4)(__VA_ARGS__)
+
+#define setxattr(...) \
+	OPENPHONE_DARWIN_SELECT5_OR_6(__VA_ARGS__, setxattr, openphone_darwin_setxattr5)(__VA_ARGS__)
+#define lsetxattr(path, name, value, size, flags) \
+	openphone_darwin_lsetxattr5(path, name, value, size, flags)
+#define fsetxattr(...) \
+	OPENPHONE_DARWIN_SELECT5_OR_6(__VA_ARGS__, fsetxattr, openphone_darwin_fsetxattr5)(__VA_ARGS__)
+
+#endif
