From 2e46a3db03ce7628f2821c393aef9e3aa66d1dc3 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Tue, 26 May 2026 20:45:00 +0300
Subject: [PATCH] OpenPhone: allow Darwin arm64 host builds

Apple Silicon hosts report `uname -sm` as `Darwin arm64`. The checked-in
Darwin build tools in this tree are universal binaries, but envsetup only
assigns HOST_ARCH for x86 and x86_64. Assign arm64 so local OpenPhone
bootstrap builds can proceed on Apple Silicon machines.
---
 core/envsetup.mk | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/core/envsetup.mk b/core/envsetup.mk
index f82e861abf..c298151370 100644
--- a/core/envsetup.mk
+++ b/core/envsetup.mk
@@ -177,10 +177,15 @@ ifneq (,$(findstring x86_64,$(UNAME)))
   HOST_2ND_ARCH := x86
   HOST_IS_64_BIT := true
 else
+ifneq (,$(findstring arm64,$(UNAME)))
+  HOST_ARCH := arm64
+  HOST_IS_64_BIT := true
+else
 ifneq (,$(findstring i686,$(UNAME))$(findstring x86,$(UNAME)))
 $(error Building on a 32-bit x86 host is not supported: $(UNAME)!)
 endif
 endif
+endif
 
 ifeq ($(HOST_OS),darwin)
   # Mac no longer supports 32-bit executables
-- 
