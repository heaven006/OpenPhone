+package android.openphone;
+
+import android.annotation.NonNull;
+import android.annotation.SystemService;
+import android.content.Context;
+import android.os.RemoteException;
+
+/**
+ * Client API for the OpenPhone agent system service.
+ *
+ * @hide
+ */
+@SystemService(Context.OPENPHONE_AGENT_SERVICE)
+public final class OpenPhoneAgentManager {
+    private final IOpenPhoneAgentService mService;
+
+    /** @hide */
+    public OpenPhoneAgentManager(@NonNull IOpenPhoneAgentService service) {
+        mService = service;
+    }
+
+    /** @hide */
+    @NonNull
+    public String getServiceStatus() {
+        try {
+            return mService.getServiceStatus();
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String startTask(@NonNull String taskRequestJson) {
+        try {
+            return mService.startTask(taskRequestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String getScreenContext(@NonNull String taskId) {
+        try {
+            return mService.getScreenContext(taskId);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String executeAction(@NonNull String taskId, @NonNull String actionRequestJson) {
+        try {
+            return mService.executeAction(taskId, actionRequestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String evaluateCapability(@NonNull String capabilityId) {
+        try {
+            return mService.evaluateCapability(capabilityId);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+}
