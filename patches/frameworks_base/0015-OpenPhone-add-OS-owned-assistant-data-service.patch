+        @Override
+        public String watcherQuery(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String mode = request.optString("mode", "active").trim();
+            final long now = request.optLong("now", System.currentTimeMillis());
+            final int limit = boundLimit(request.optInt("limit", 20));
+            final String watcherColumns = "id, type, title, condition_json, schedule_json, "
+                    + "session_target, delivery_json, status, created_at, updated_at, "
+                    + "next_run_at, running_at, last_run_at, last_result_hash, "
+                    + "failure_count, failure_alert_at";
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    if ("next_run_at".equals(mode)) {
+                        long nextRunAt = 0L;
+                        try (Cursor cursor = db.rawQuery("SELECT next_run_at FROM watcher "
+                                + "WHERE status = 'active' AND deleted_at IS NULL "
+                                + "AND next_run_at > ? ORDER BY next_run_at ASC LIMIT 1",
+                                new String[]{Long.toString(now)})) {
+                            if (cursor.moveToFirst()) {
+                                nextRunAt = cursor.getLong(0);
+                            }
+                        }
+                        return new JSONObject().put("next_run_at", nextRunAt).toString();
+                    }
+                    final JSONArray watchers = new JSONArray();
+                    if ("due".equals(mode)) {
+                        try (Cursor cursor = db.rawQuery("SELECT " + watcherColumns
+                                + " FROM watcher WHERE status = 'active' "
+                                + "AND deleted_at IS NULL "
+                                + "AND next_run_at > 0 AND next_run_at <= ? "
+                                + "ORDER BY next_run_at ASC LIMIT ?",
+                                new String[]{Long.toString(now), Integer.toString(limit)})) {
+                            readWatchersLocked(cursor, watchers);
+                        }
+                        return wrapArray("watchers", watchers);
+                    }
+                    if ("active_by_type".equals(mode)) {
+                        final String type = safeLower(request.optString("type", ""), "");
+                        if (type.isEmpty()) {
+                            return wrapArray("watchers", watchers);
+                        }
+                        try (Cursor cursor = db.rawQuery("SELECT " + watcherColumns
+                                + " FROM watcher WHERE status = 'active' "
+                                + "AND deleted_at IS NULL AND type = ? "
+                                + "ORDER BY updated_at ASC LIMIT ?",
+                                new String[]{type, Integer.toString(limit)})) {
+                            readWatchersLocked(cursor, watchers);
+                        }
+                        return wrapArray("watchers", watchers);
+                    }
+                    if ("search".equals(mode)) {
+                        final String query = request.optString("query", "").trim();
+                        if (!query.isEmpty()) {
+                            final String ftsQuery = query.replace('"', ' ').trim();
+                            try (Cursor cursor = db.rawQuery("SELECT w.id, w.type, w.title, "
+                                    + "w.condition_json, w.schedule_json, w.session_target, "
+                                    + "w.delivery_json, w.status, w.created_at, w.updated_at, "
+                                    + "w.next_run_at, w.running_at, w.last_run_at, "
+                                    + "w.last_result_hash, w.failure_count, w.failure_alert_at "
+                                    + "FROM watcher_fts f JOIN watcher w ON w.id = f.rowid "
+                                    + "WHERE watcher_fts MATCH ? AND w.deleted_at IS NULL "
+                                    + "ORDER BY w.updated_at DESC LIMIT ?",
+                                    new String[]{ftsQuery, Integer.toString(limit)})) {
+                                readWatchersLocked(cursor, watchers);
+                                return wrapArray("watchers", watchers);
+                            } catch (RuntimeException e) {
+                                // Malformed FTS query: fall through to active.
+                            }
+                        }
+                    }
+                    try (Cursor cursor = db.rawQuery("SELECT " + watcherColumns
+                            + " FROM watcher WHERE status = 'active' AND deleted_at IS NULL "
+                            + "ORDER BY next_run_at ASC, updated_at DESC LIMIT ?",
+                            new String[]{Integer.toString(limit)})) {
+                        readWatchersLocked(cursor, watchers);
+                    }
+                    return wrapArray("watchers", watchers);
+                } catch (JSONException e) {
+                    throw new IllegalStateException(e);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "watcherQuery failed", e);
+                    return errorJson("query_failed");
+                }
+            }
+        }
