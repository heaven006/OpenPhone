diff --git a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
index d04e9fb1b99e..13fef2139397 100644
--- a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
+++ b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
@@ -82,6 +82,12 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             "org.openphone.permission.MANAGE_AGENT_TASKS";
     private static final String PERMISSION_READ_AGENT_AUDIT_LOG =
             "org.openphone.permission.READ_AGENT_AUDIT_LOG";
+    private static final String PERMISSION_SUBMIT_UI_TREE_SNAPSHOT =
+            "org.openphone.permission.SUBMIT_UI_TREE_SNAPSHOT";
+    // UI tree snapshots are short-lived; if no producer has submitted within
+    // this TTL the framework returns an empty payload rather than serving
+    // stale UI to the model.
+    private static final long UI_TREE_SNAPSHOT_TTL_MS = 30_000L;
     private static final String OPENPHONE_SYSTEM_DIR = "openphone";
     private static final String AUDIT_LOG_FILE = "audit-log.json";
     // Tamper-evident audit log: each event carries a monotonically
@@ -127,6 +133,10 @@ public final class OpenPhoneAgentManagerService extends SystemService {
         private final ArrayDeque<String> mPointerEvents = new ArrayDeque<>(MAX_AUDIT_EVENTS);
         private final Object mPendingActionLock = new Object();
         private final Map<String, PendingAction> mPendingActions = new HashMap<>();
+        private final Object mUiTreeLock = new Object();
+        private String mUiTreeSnapshot = "";
+        private long mUiTreeSnapshotElapsedMs = 0L;
+        private int mUiTreeSnapshotProducerUid = 0;
         private final String mBootId = UUID.randomUUID().toString();
         private long mAuditSeq = 0L;
         private String mAuditChainHead = AUDIT_GENESIS_HASH;
@@ -268,6 +278,88 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             return result;
         }
 
+        @Override
+        public String submitUiTreeSnapshot(String snapshotJson) {
+            mContext.enforceCallingOrSelfPermission(
+                    PERMISSION_SUBMIT_UI_TREE_SNAPSHOT,
+                    "OpenPhone UI tree submit requires SUBMIT_UI_TREE_SNAPSHOT");
+            final int callerUid = Binder.getCallingUid();
+            final String clean = snapshotJson == null ? "" : snapshotJson;
+            // Validate that the payload at least parses as JSON before caching;
+            // a malformed string should not poison getScreenContext().
+            try {
+                new JSONObject(clean);
+            } catch (JSONException e) {
+                return errorJson("invalid_snapshot_json");
+            }
+            final long now;
+            synchronized (mUiTreeLock) {
+                mUiTreeSnapshot = clean;
+                mUiTreeSnapshotElapsedMs = SystemClock.elapsedRealtime();
+                mUiTreeSnapshotProducerUid = callerUid;
+                now = mUiTreeSnapshotElapsedMs;
+            }
+            recordAudit("ui_tree_snapshot_submitted", null, "screen.read.visible",
+                    "allow_task_scoped", null,
+                    "producer_uid=" + callerUid + " bytes=" + clean.length());
+            try {
+                return new JSONObject()
+                        .put("accepted", true)
+                        .put("submitted_elapsed_ms", now)
+                        .put("bytes", clean.length())
+                        .toString();
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+        }
+
+        @Override
+        public String getUiTreeSnapshot() {
+            enforceReadScreenContext();
+            final String snapshot;
+            final long age;
+            final int producer;
+            synchronized (mUiTreeLock) {
+                if (mUiTreeSnapshotElapsedMs == 0L) {
+                    return emptyUiTreeSnapshot("never_submitted");
+                }
+                age = SystemClock.elapsedRealtime() - mUiTreeSnapshotElapsedMs;
+                if (age > UI_TREE_SNAPSHOT_TTL_MS) {
+                    return emptyUiTreeSnapshot("stale_ttl_ms=" + age);
+                }
+                snapshot = mUiTreeSnapshot;
+                producer = mUiTreeSnapshotProducerUid;
+            }
+            try {
+                return new JSONObject()
+                        .put("snapshot", new JSONObject(snapshot))
+                        .put("age_ms", age)
+                        .put("producer_uid", producer)
+                        .toString();
+            } catch (JSONException e) {
+                return emptyUiTreeSnapshot("snapshot_parse_failed");
+            }
+        }
+
+        private static String emptyUiTreeSnapshot(String reason) {
+            try {
+                return new JSONObject()
+                        .put("snapshot", JSONObject.NULL)
+                        .put("reason", reason)
+                        .toString();
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+        }
+
+        private static String errorJson(String error) {
+            try {
+                return new JSONObject().put("error", error).toString();
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+        }
+
         @Override
         public String getAuditLog(int maxEvents) {
             enforceReadAuditLog();
@@ -329,6 +421,23 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             return activeTaskIds;
         }
 
+        private JSONObject freshUiTreeSnapshot() {
+            synchronized (mUiTreeLock) {
+                if (mUiTreeSnapshotElapsedMs == 0L) {
+                    return null;
+                }
+                final long age = SystemClock.elapsedRealtime() - mUiTreeSnapshotElapsedMs;
+                if (age > UI_TREE_SNAPSHOT_TTL_MS) {
+                    return null;
+                }
+                try {
+                    return new JSONObject(mUiTreeSnapshot);
+                } catch (JSONException e) {
+                    return null;
+                }
+            }
+        }
+
         private String screenContextJson(String taskId) {
             JSONObject json = new JSONObject();
             try {
@@ -344,8 +453,22 @@ public final class OpenPhoneAgentManagerService extends SystemService {
                 json.put("activity", focusedComponent == null
                         ? JSONObject.NULL : focusedComponent.flattenToShortString());
                 json.put("visible_activities", visibleActivitiesJson(visibleActivities));
-                json.put("visible_text", new JSONArray());
-                json.put("interactive_elements", new JSONArray());
+                final JSONObject uiTree = freshUiTreeSnapshot();
+                if (uiTree != null) {
+                    json.put("visible_text", uiTree.optJSONArray("visible_text") == null
+                            ? new JSONArray() : uiTree.getJSONArray("visible_text"));
+                    json.put("interactive_elements",
+                            uiTree.optJSONArray("interactive_elements") == null
+                                    ? new JSONArray()
+                                    : uiTree.getJSONArray("interactive_elements"));
+                    json.put("ui_tree_age_ms",
+                            SystemClock.elapsedRealtime() - mUiTreeSnapshotElapsedMs);
+                    json.put("ui_tree_source", "framework_cached_snapshot");
+                } else {
+                    json.put("visible_text", new JSONArray());
+                    json.put("interactive_elements", new JSONArray());
+                    json.put("ui_tree_source", "framework_cached_snapshot_unavailable");
+                }
                 json.put("notifications", new JSONArray());
                 json.put("risk_flags", screenContextRiskFlags(visibleActivities));
                 json.put("source", "system_server.activity_task_manager");
