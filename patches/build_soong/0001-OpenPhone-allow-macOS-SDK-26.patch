From 9307b34bef3b70ea474e5c22e261a044a1918c91 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Tue, 26 May 2026 21:00:00 +0300
Subject: [PATCH 1/3] OpenPhone: allow macOS SDK 26

Local OpenPhone bootstrap builds may run on newer macOS/Xcode versions than
this Android branch originally allowlisted. Permit SDK 26.x so Soong can
resolve Darwin host toolchains on this machine.

diff --git a/cc/config/darwin_host.go b/cc/config/darwin_host.go
index 03eefc096..982c2aeb3 100644
--- a/cc/config/darwin_host.go
+++ b/cc/config/darwin_host.go
@@ -55,6 +55,7 @@ var (
 		"13",
 		"14",
 		"15",
+		"26",
 	}
 
 	darwinAvailableLibraries = append(
-- 
