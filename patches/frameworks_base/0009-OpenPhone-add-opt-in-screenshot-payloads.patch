+        private static final class ScreenPayload {
+            final String captureMode;
+            final String mimeType;
+            final int width;
+            final int height;
+            final int quality;
+            final String base64;
+            final String error;
+
+            private ScreenPayload(String captureMode, String mimeType, int width, int height,
+                    int quality, String base64, String error) {
+                this.captureMode = captureMode;
+                this.mimeType = mimeType;
+                this.width = width;
+                this.height = height;
+                this.quality = quality;
+                this.base64 = base64;
+                this.error = error;
+            }
+
+            static ScreenPayload none() {
+                return new ScreenPayload("metadata_only", null, 0, 0, 0, null, null);
+            }
+
+            static ScreenPayload error(String error) {
+                return new ScreenPayload("metadata_only", null, 0, 0, 0, null, error);
+            }
+
+            static ScreenPayload jpegBase64(int width, int height, int quality, String base64) {
+                return new ScreenPayload("screenshot_jpeg_base64", "image/jpeg", width, height,
+                        quality, base64, null);
+            }
+
+            boolean hasScreenshot() {
+                return base64 != null;
+            }
+
+            String auditDetail() {
+                if (hasScreenshot()) {
+                    return captureMode + ":" + width + "x" + height;
+                }
+                return error == null ? captureMode : captureMode + ":" + error;
+            }
+
+            JSONObject toJson() throws JSONException {
+                return new JSONObject()
+                        .put("mime_type", mimeType)
+                        .put("encoding", "base64")
+                        .put("width", width)
+                        .put("height", height)
+                        .put("quality", quality)
+                        .put("data", base64);
+            }
+        }
+
