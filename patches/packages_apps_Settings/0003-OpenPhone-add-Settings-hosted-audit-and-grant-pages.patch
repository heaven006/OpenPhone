+package com.android.settings.openphone;
+
+import android.app.settings.SettingsEnums;
+import android.content.Context;
+import android.openphone.OpenPhoneAgentManager;
+import android.text.TextUtils;
+
+import androidx.preference.Preference;
+
+import com.android.settings.R;
+import com.android.settings.dashboard.DashboardFragment;
+import com.android.settings.search.BaseSearchIndexProvider;
+import com.android.settingslib.search.SearchIndexable;
+
+@SearchIndexable
+public class OpenPhoneAuditSettings extends DashboardFragment {
+    private static final String TAG = "OpenPhoneAudit";
+    private static final String KEY_SERVICE_STATUS = "openphone_audit_service_status";
+    private static final String KEY_RECENT_AUDIT = "openphone_recent_audit";
+    private static final int MAX_AUDIT_EVENTS = 10;
+    private static final int MAX_SUMMARY_CHARS = 1200;
+
+    @Override
+    public int getMetricsCategory() {
+        return SettingsEnums.DASHBOARD_SUMMARY;
+    }
+
+    @Override
+    protected String getLogTag() {
+        return TAG;
+    }
+
+    @Override
+    protected int getPreferenceScreenResId() {
+        return R.xml.openphone_audit;
+    }
+
+    @Override
+    public void onResume() {
+        super.onResume();
+        updateAuditState();
+    }
+
+    private void updateAuditState() {
+        Context context = getContext();
+        OpenPhoneAgentManager manager = context == null
+                ? null : context.getSystemService(OpenPhoneAgentManager.class);
+        if (manager == null) {
+            setSummary(KEY_SERVICE_STATUS, getString(R.string.openphone_service_unavailable));
+            setSummary(KEY_RECENT_AUDIT, getString(R.string.openphone_audit_empty));
+            return;
+        }
+
+        try {
+            setSummary(KEY_SERVICE_STATUS, summarize(manager.getServiceStatus()));
+            setSummary(KEY_RECENT_AUDIT, summarize(manager.getAuditLog(MAX_AUDIT_EVENTS)));
+        } catch (RuntimeException e) {
+            setSummary(KEY_SERVICE_STATUS, e.getClass().getSimpleName());
+            setSummary(KEY_RECENT_AUDIT, getString(R.string.openphone_audit_empty));
+        }
+    }
+
+    private void setSummary(String key, CharSequence summary) {
+        Preference preference = findPreference(key);
+        if (preference != null) {
+            preference.setSummary(summary);
+        }
+    }
+
+    private String summarize(String value) {
+        if (TextUtils.isEmpty(value)) {
+            return getString(R.string.openphone_audit_empty);
+        }
+        String compact = value.replace(String.valueOf((char) 10), " ")
+                .replace(String.valueOf((char) 13), " ").trim();
+        if (compact.length() <= MAX_SUMMARY_CHARS) {
+            return compact;
+        }
+        return compact.substring(0, MAX_SUMMARY_CHARS) + "...";
+    }
+
+    public static final BaseSearchIndexProvider SEARCH_INDEX_DATA_PROVIDER =
+            new BaseSearchIndexProvider(R.xml.openphone_audit);
+}
