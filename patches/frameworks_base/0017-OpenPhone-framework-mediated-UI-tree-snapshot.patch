+    <!-- @hide Allows OpenPhone privileged producers to submit a UI tree snapshot. -->
+    <permission
+        android:name="org.openphone.permission.SUBMIT_UI_TREE_SNAPSHOT"
+        android:protectionLevel="signature" />
 
     <!-- ================================================ -->
