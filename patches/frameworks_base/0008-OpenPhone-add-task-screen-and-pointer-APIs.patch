+        @Override
+        public String getScreen(String taskId, String requestJson) {
+            enforceReadScreenContext();
+            if (!isTaskActive(taskId)) {
+                recordAudit("screen_capture_rejected", taskId, "screen.read.visible",
+                        "deny", requestJson, "task_not_active");
+                return screenResultJson("screen.denied.task_not_active", taskId, requestJson,
+                        null);
+            }
+            final String contextJson = screenContextJson(taskId);
+            recordAudit("screen_capture", taskId, "screen.read.visible",
+                    "allow_task_scoped", requestJson, "metadata_only");
+            return screenResultJson("screen.captured.metadata_only", taskId, requestJson,
+                    contextJson);
+        }
+
+        @Override
+        public String watchScreen(String taskId, String requestJson) {
+            enforceReadScreenContext();
+            if (!isTaskActive(taskId)) {
+                recordAudit("screen_watch_rejected", taskId, "screen.read.visible",
+                        "deny", requestJson, "task_not_active");
+                return screenResultJson("screen.denied.task_not_active", taskId, requestJson,
+                        null);
+            }
+            recordAudit("screen_watch_started", taskId, "screen.read.visible",
+                    "allow_task_scoped", requestJson, "metadata_only");
+            return screenResultJson("screen.watch.metadata_only", taskId, requestJson,
+                    screenContextJson(taskId));
+        }
+
+        @Override
+        public String stopTask(String taskId, String reasonJson) {
+            enforceManageTasks();
+            synchronized (mTaskLock) {
+                if (!mTaskStates.containsKey(taskId)) {
+                    return taskStopJson("task.denied.unknown", taskId, reasonJson);
+                }
+                mTaskStates.put(taskId, "stopped");
+            }
+            recordAudit("task_stopped", taskId, "tasks.observe", "allow_task_scoped",
+                    reasonJson, null);
+            return taskStopJson("task.stopped", taskId, reasonJson);
+        }
+
+        @Override
+        public String getPointerEvents(String taskId, int maxEvents) {
+            enforceReadAuditLog();
+            return pointerEventsJson(taskId, maxEvents);
+        }
+
         @Override
         public String executeAction(String taskId, String actionRequestJson) {
             enforcePerformDeviceAction();
