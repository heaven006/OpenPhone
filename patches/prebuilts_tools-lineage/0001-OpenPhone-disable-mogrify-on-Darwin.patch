From 35c82328928759b8f411afdde5ddf1baa0876d40 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Tue, 26 May 2026 20:50:00 +0300
Subject: [PATCH] OpenPhone: disable mogrify on Darwin

The Lineage tools prebuilt tree only ships `mogrify` for linux-x86. Provide a
Darwin shim source so Soong can analyze the module during local macOS
bootstrap builds. The shim delegates to ImageMagick when a build step actually
needs `mogrify`.

Change-Id: Iedec9250b83bfb23a45d69b21ef68684012a8414

diff --git a/Android.bp b/Android.bp
index e4b0f2d..2e55dd0 100644
--- a/Android.bp
+++ b/Android.bp
@@ -11,6 +11,9 @@ prebuilt_build_tool {
         },
     },
     target: {
+        darwin: {
+            src: "darwin-x86/bin/alsatplg",
+        },
         linux: {
             src: "linux-x86/bin/alsatplg",
         },
@@ -26,6 +29,9 @@ prebuilt_build_tool {
         },
     },
     target: {
+        darwin: {
+            src: "darwin-x86/bin/mogrify",
+        },
         linux: {
             src: "linux-x86/bin/mogrify",
         },
diff --git a/darwin-x86/bin/alsatplg b/darwin-x86/bin/alsatplg
new file mode 100755
index 0000000..b140453
--- /dev/null
+++ b/darwin-x86/bin/alsatplg
@@ -0,0 +1,9 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if command -v alsatplg >/dev/null 2>&1; then
+  exec alsatplg "$@"
+fi
+
+echo "alsatplg is required for this build step; install an ALSA topology compiler" >&2
+exit 127
diff --git a/darwin-x86/bin/mogrify b/darwin-x86/bin/mogrify
new file mode 100755
index 0000000..76f3b50
--- /dev/null
+++ b/darwin-x86/bin/mogrify
@@ -0,0 +1,13 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if command -v magick >/dev/null 2>&1; then
+  exec magick mogrify "$@"
+fi
+
+if command -v mogrify >/dev/null 2>&1; then
+  exec mogrify "$@"
+fi
+
+echo "mogrify is required for this build step; install ImageMagick" >&2
+exit 127
-- 
