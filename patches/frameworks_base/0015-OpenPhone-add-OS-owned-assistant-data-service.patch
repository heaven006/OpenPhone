+        // Storage
+        // ---------------------------------------------------------------
+
+        private SQLiteDatabase openLocked() {
+            if (mDb != null && mDb.isOpen()) {
+                return mDb;
+            }
+            final File dir = new File(Environment.getDataSystemDirectory(),
+                    OPENPHONE_SYSTEM_DIR);
+            if (!dir.exists() && !dir.mkdirs()) {
+                throw new IllegalStateException(
+                        "Unable to create OpenPhone system directory: " + dir);
+            }
+            final SQLiteDatabase db = SQLiteDatabase.openOrCreateDatabase(
+                    new File(dir, DB_FILE), null);
+            final int version = db.getVersion();
+            if (version < SCHEMA_VERSION) {
+                db.beginTransaction();
+                try {
+                    // Durable user data: migrations must be additive and stepwise,
+                    // never DROP TABLE.
+                    if (version < 1) {
+                        createSchemaLocked(db);
+                    }
+                    db.setVersion(SCHEMA_VERSION);
+                    db.setTransactionSuccessful();
+                } finally {
+                    db.endTransaction();
+                }
+            }
+            mDb = db;
+            return db;
+        }
