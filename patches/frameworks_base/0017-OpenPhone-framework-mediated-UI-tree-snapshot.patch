From 605c44982c091505046c6cce4abaecfc5aecf591 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Fri, 12 Jun 2026 09:08:25 +0000
Subject: [PATCH] OpenPhone: framework-mediated UI tree snapshot path

The accessibility-derived UI tree snapshot is now submitted to
system_server through a binder method (submitUiTreeSnapshot) gated
by a SUBMIT_UI_TREE_SNAPSHOT signature permission. The framework
caches it with a 30-second TTL and merges visible_text plus
interactive_elements into getScreenContext output (gated by
READ_SCREEN_CONTEXT) so privileged consumers no longer need to
bind the assistant accessibility service directly. A
ui_tree_snapshot_submitted audit event records each producer
write into the hash-chained audit log.

Change-Id: I9e0f3a5b7283041a5b6c7d8e9f0a1b2c3d4e5f60
---
 .../openphone/IOpenPhoneAgentService.aidl     |   2 +
 .../openphone/OpenPhoneAgentManager.java      |  32 +++++
 core/res/AndroidManifest.xml                  |   4 +
 .../OpenPhoneAgentManagerService.java         | 127 +++++++++++++++++-
 4 files changed, 163 insertions(+), 2 deletions(-)

diff --git a/core/java/android/openphone/IOpenPhoneAgentService.aidl b/core/java/android/openphone/IOpenPhoneAgentService.aidl
index d4d461630942..45bc216cccbe 100644
--- a/core/java/android/openphone/IOpenPhoneAgentService.aidl
+++ b/core/java/android/openphone/IOpenPhoneAgentService.aidl
@@ -13,4 +13,6 @@ interface IOpenPhoneAgentService {
     String confirmAction(String pendingActionId, boolean approved);
     String evaluateCapability(String capabilityId);
     String getAuditLog(int maxEvents);
+    String submitUiTreeSnapshot(String snapshotJson);
+    String getUiTreeSnapshot();
 }
diff --git a/core/java/android/openphone/OpenPhoneAgentManager.java b/core/java/android/openphone/OpenPhoneAgentManager.java
index 94f3e2220eae..e34f8a6c2aef 100644
--- a/core/java/android/openphone/OpenPhoneAgentManager.java
+++ b/core/java/android/openphone/OpenPhoneAgentManager.java
@@ -144,4 +144,36 @@ public final class OpenPhoneAgentManager {
             throw e.rethrowFromSystemServer();
         }
     }
+
+    /**
+     * Submit a UI tree snapshot from a privileged producer (the OpenPhone
+     * accessibility service). Requires the SUBMIT_UI_TREE_SNAPSHOT signature
+     * permission; the framework caches the snapshot with a TTL so callers of
+     * {@link #getScreenContext(String)} get a fresh, validated view.
+     *
+     * @hide
+     */
+    @NonNull
+    public String submitUiTreeSnapshot(@NonNull String snapshotJson) {
+        try {
+            return mService.submitUiTreeSnapshot(snapshotJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /**
+     * Read the latest UI tree snapshot held by the framework, or {@code null}
+     * if no producer has submitted within the TTL. Requires READ_SCREEN_CONTEXT.
+     *
+     * @hide
+     */
+    @NonNull
+    public String getUiTreeSnapshot() {
+        try {
+            return mService.getUiTreeSnapshot();
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
 }
diff --git a/core/res/AndroidManifest.xml b/core/res/AndroidManifest.xml
index 02db52bb4869..4e28cdfe3d26 100644
--- a/core/res/AndroidManifest.xml
+++ b/core/res/AndroidManifest.xml
@@ -49,6 +49,10 @@
     <permission
         android:name="org.openphone.permission.USE_ASSISTANT_DATA"
