@@ -455,6 +463,79 @@ public final class OpenPhoneAgentManagerService extends SystemService {
                     taskId, actionRequestJson, capability, "type_text");
         }
 
+        private String executeClipboardWrite(String taskId, String actionRequestJson,
+                JSONObject request, String capability) {
+            final String text = request.optString("text", "");
+            if (text.isEmpty()) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_text");
+                return actionResultJson("action.denied.missing_text", taskId, actionRequestJson,
+                        capability, "missing_text");
+            }
+
+            final ClipboardManager clipboardManager =
+                    mContext.getSystemService(ClipboardManager.class);
+            if (clipboardManager == null) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "clipboard_unavailable");
+                return actionResultJson("action.denied.clipboard_unavailable", taskId,
+                        actionRequestJson, capability, "clipboard_unavailable");
+            }
+
+            final long token = Binder.clearCallingIdentity();
+            try {
+                clipboardManager.setPrimaryClip(ClipData.newPlainText("OpenPhone", text));
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+
+            recordAudit("action_executed", taskId, capability, "allow_task_scoped",
+                    actionRequestJson, "clipboard_write");
+            return actionResultJson("action.executed", taskId, actionRequestJson, capability,
+                    "clipboard_write");
+        }
+
+        private String executeClipboardPaste(String taskId, String actionRequestJson,
+                String capability) {
+            final ClipboardManager clipboardManager =
+                    mContext.getSystemService(ClipboardManager.class);
+            if (clipboardManager == null) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "clipboard_unavailable");
+                return actionResultJson("action.denied.clipboard_unavailable", taskId,
+                        actionRequestJson, capability, "clipboard_unavailable");
+            }
+
+            final ClipData clip;
+            final long token = Binder.clearCallingIdentity();
+            try {
+                clip = clipboardManager.getPrimaryClip();
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+            if (clip == null || clip.getItemCount() <= 0) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "clipboard_empty");
+                return actionResultJson("action.denied.clipboard_empty", taskId,
+                        actionRequestJson, capability, "clipboard_empty");
+            }
+
+            final CharSequence text = clip.getItemAt(0).coerceToText(mContext);
+            if (text == null || text.length() == 0) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "clipboard_text_unavailable");
+                return actionResultJson("action.denied.clipboard_text_unavailable", taskId,
+                        actionRequestJson, capability, "clipboard_text_unavailable");
+            }
+
+            final boolean injected = injectText(text.toString());
+            recordAudit(injected ? "action_executed" : "action_rejected", taskId, capability,
+                    injected ? "allow_task_scoped" : "deny", actionRequestJson,
+                    "clipboard_paste");
+            return actionResultJson(injected ? "action.executed" : "action.denied.input_failed",
+                    taskId, actionRequestJson, capability, "clipboard_paste");
+        }
+
         private String actionResultJson(String state, String taskId, String inputJson,
                 String capability, String detail) {
             return actionResultJson(state, taskId, inputJson, capability, detail, null);
@@ -570,6 +651,12 @@ public final class OpenPhoneAgentManagerService extends SystemService {
                     || "scroll".equals(type) || "type_text".equals(type)) {
                 return "input.perform";
             }
