+
+package android.openphone;
+
+import android.annotation.NonNull;
+import android.annotation.SystemService;
+import android.content.Context;
+import android.os.RemoteException;
+
+/**
+ * Client API for the OS-owned OpenPhone assistant data service
+ * (memories, commitments and watchers).
+ *
+ * @hide
+ */
+@SystemService(Context.OPENPHONE_ASSISTANT_DATA_SERVICE)
+public final class OpenPhoneAssistantDataManager {
+    private final IOpenPhoneAssistantDataService mService;
+
+    /** @hide */
+    public OpenPhoneAssistantDataManager(@NonNull IOpenPhoneAssistantDataService service) {
+        mService = service;
+    }
+
+    /** @hide */
+    @NonNull
+    public String getServiceStatus() {
+        try {
+            return mService.getServiceStatus();
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String memorySave(@NonNull String requestJson) {
+        try {
+            return mService.memorySave(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String memoryQuery(@NonNull String requestJson) {
+        try {
+            return mService.memoryQuery(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String commitmentCreate(@NonNull String requestJson) {
+        try {
+            return mService.commitmentCreate(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String commitmentUpdate(@NonNull String requestJson) {
+        try {
+            return mService.commitmentUpdate(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String commitmentQuery(@NonNull String requestJson) {
+        try {
+            return mService.commitmentQuery(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String watcherCreate(@NonNull String requestJson) {
+        try {
+            return mService.watcherCreate(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String watcherUpdate(@NonNull String requestJson) {
+        try {
+            return mService.watcherUpdate(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String watcherQuery(@NonNull String requestJson) {
+        try {
+            return mService.watcherQuery(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String migrateRows(@NonNull String store, @NonNull String rowsJsonArray) {
+        try {
+            return mService.migrateRows(store, rowsJsonArray);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+}
