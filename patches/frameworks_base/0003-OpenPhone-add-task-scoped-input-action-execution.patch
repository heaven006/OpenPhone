+        private Set<String> approvedCapabilities(String taskRequestJson) {
+            final HashSet<String> grants = new HashSet<>();
+            if (taskRequestJson == null || taskRequestJson.isEmpty()) {
+                return grants;
+            }
+            try {
+                final JSONObject request = new JSONObject(taskRequestJson);
+                addStringArray(grants, request.optJSONArray("approved_capabilities"));
+                addStringArray(grants, request.optJSONArray("granted_capabilities"));
+            } catch (JSONException e) {
+                Slog.w(TAG, "Ignoring malformed task grant payload", e);
+            }
+            return grants;
+        }
+
+        private boolean taskHasGrant(String taskId, String capability) {
+            synchronized (mTaskLock) {
+                final Set<String> grants = mTaskGrants.get(taskId);
+                return grants != null && grants.contains(capability);
+            }
+        }
+
+        private static void addStringArray(Set<String> output, JSONArray values) {
+            if (values == null) {
+                return;
+            }
+            for (int i = 0; i < values.length(); i++) {
+                final String value = values.optString(i, "");
+                if (!value.isEmpty()) {
+                    output.add(value);
+                }
+            }
+        }
+
+        private static JSONArray stringSetJson(Set<String> values) {
+            final JSONArray json = new JSONArray();
+            for (String value : values) {
+                json.put(value);
+            }
+            return json;
+        }
+
+        private boolean injectKey(int keyCode) {
+            final long now = SystemClock.uptimeMillis();
+            final KeyEvent down = new KeyEvent(now, now, KeyEvent.ACTION_DOWN, keyCode,
+                    0, 0, KeyCharacterMap.VIRTUAL_KEYBOARD, 0,
+                    KeyEvent.FLAG_FROM_SYSTEM, InputDevice.SOURCE_KEYBOARD);
+            final KeyEvent up = new KeyEvent(now, now, KeyEvent.ACTION_UP, keyCode,
+                    0, 0, KeyCharacterMap.VIRTUAL_KEYBOARD, 0,
+                    KeyEvent.FLAG_FROM_SYSTEM, InputDevice.SOURCE_KEYBOARD);
+            return injectInputEvent(down) && injectInputEvent(up);
+        }
+
+        private boolean injectTap(float x, float y, long pressDurationMs) {
+            final long downTime = SystemClock.uptimeMillis();
+            return injectMotion(MotionEvent.ACTION_DOWN, downTime, downTime, x, y)
+                    && injectMotion(MotionEvent.ACTION_UP, downTime,
+                            downTime + pressDurationMs, x, y);
+        }
+
+        private boolean injectSwipe(float startX, float startY, float endX, float endY,
+                long durationMs) {
+            final long downTime = SystemClock.uptimeMillis();
+            boolean injected = injectMotion(MotionEvent.ACTION_DOWN, downTime, downTime,
+                    startX, startY);
+            final int steps = 8;
+            for (int i = 1; i < steps && injected; i++) {
+                final float alpha = (float) i / steps;
+                injected &= injectMotion(MotionEvent.ACTION_MOVE, downTime,
+                        downTime + (durationMs * i / steps),
+                        lerp(startX, endX, alpha), lerp(startY, endY, alpha));
+            }
+            return injected && injectMotion(MotionEvent.ACTION_UP, downTime,
+                    downTime + durationMs, endX, endY);
+        }
+
+        private boolean injectMotion(int action, long downTime, long eventTime, float x, float y) {
+            final MotionEvent.PointerProperties[] properties =
+                    new MotionEvent.PointerProperties[1];
+            properties[0] = new MotionEvent.PointerProperties();
+            properties[0].id = 0;
+            properties[0].toolType = MotionEvent.TOOL_TYPE_FINGER;
+
+            final MotionEvent.PointerCoords[] coords = new MotionEvent.PointerCoords[1];
+            coords[0] = new MotionEvent.PointerCoords();
+            coords[0].x = x;
+            coords[0].y = y;
+            coords[0].pressure = action == MotionEvent.ACTION_UP ? 0.0f : 1.0f;
+            coords[0].size = 1.0f;
+
+            final MotionEvent event = MotionEvent.obtain(downTime, eventTime, action, 1,
+                    properties, coords, 0, 0, 1.0f, 1.0f, 0, 0,
+                    InputDevice.SOURCE_TOUCHSCREEN, Display.DEFAULT_DISPLAY, 0);
+            return injectInputEvent(event);
+        }
+
+        private boolean injectInputEvent(android.view.InputEvent event) {
+            final InputManager inputManager = mContext.getSystemService(InputManager.class);
+            if (inputManager == null) {
+                return false;
+            }
+            final long token = Binder.clearCallingIdentity();
+            try {
+                return inputManager.injectInputEvent(event,
+                        InputManager.INJECT_INPUT_EVENT_MODE_WAIT_FOR_FINISH);
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+        }
+
+        private static float optFloat(JSONObject json, String key, float defaultValue) {
+            if (json == null || !json.has(key)) {
+                return defaultValue;
+            }
+            return (float) json.optDouble(key, defaultValue);
+        }
+
+        private static float lerp(float start, float end, float alpha) {
+            return start + ((end - start) * alpha);
+        }
