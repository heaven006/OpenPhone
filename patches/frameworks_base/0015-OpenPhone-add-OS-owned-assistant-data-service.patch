+        @Override
+        public String watcherUpdate(String requestJson) {
+            enforcePermission();
+            final JSONObject request = parseOrEmpty(requestJson);
+            final String action = request.optString("action", "").trim();
+            final long now = request.optLong("now", System.currentTimeMillis());
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    if ("repair_stuck".equals(action)) {
+                        return repairStuckLocked(db,
+                                request.optLong("stale_before", 0L), now);
+                    }
+                    final long id = request.optLong("id", 0L);
+                    if (id <= 0) {
+                        return errorJson("invalid_id");
+                    }
+                    final ContentValues values = new ContentValues();
+                    String where = "id = ?";
+                    switch (action) {
+                        case "stop":
+                            values.put("status", "stopped");
+                            values.put("updated_at", now);
+                            values.put("deleted_at", now);
+                            break;
+                        case "mark_running":
+                            values.put("running_at", now);
+                            values.put("updated_at", now);
+                            where = "id = ? AND status = 'active'";
+                            break;
+                        case "mark_fired":
+                            values.put("status", "fired");
+                            values.put("running_at", 0L);
+                            values.put("last_run_at", now);
+                            values.put("updated_at", now);
+                            values.put("last_result_hash",
+                                    request.optString("result_hash", ""));
+                            break;
+                        case "mark_failed":
+                            values.put("status", "active");
+                            values.put("running_at", 0L);
+                            values.put("last_run_at", now);
+                            values.put("updated_at", now);
+                            values.put("next_run_at", request.optLong("next_run_at", 0L));
+                            values.put("last_result_hash",
+                                    request.optString("result_hash", ""));
+                            values.put("failure_count", request.optLong("failure_count", 0L));
+                            values.put("failure_alert_at",
+                                    request.optLong("failure_alert_at", 0L));
+                            where = "id = ? AND deleted_at IS NULL";
+                            break;
+                        case "mark_noop":
+                            values.put("running_at", 0L);
+                            values.put("last_run_at", now);
+                            values.put("next_run_at", request.optLong("next_run_at", 0L));
+                            values.put("updated_at", now);
+                            if (request.has("result_hash")) {
+                                values.put("last_result_hash",
+                                        request.optString("result_hash", ""));
+                            }
+                            break;
+                        default:
+                            return errorJson("unknown_action");
+                    }
+                    final int updated = db.update("watcher", values, where,
+                            new String[]{Long.toString(id)});
+                    return updatedJson(updated > 0);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "watcherUpdate failed", e);
+                    return errorJson("update_failed");
+                }
+            }
+        }
