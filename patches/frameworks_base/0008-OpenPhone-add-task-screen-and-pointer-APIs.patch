+        private String screenResultJson(String state, String taskId, String requestJson,
+                String contextJson) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("state", state);
+                json.put("task_id", taskId);
+                json.put("request", requestJson);
+                json.put("timestamp_ms", System.currentTimeMillis());
+                json.put("screenshot_ref", JSONObject.NULL);
+                json.put("capture_mode", "metadata_only");
+                json.put("source", "system_server.openphone_agent");
+                json.put("context", contextJson == null ? JSONObject.NULL : new JSONObject(contextJson));
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private String taskStopJson(String state, String taskId, String reasonJson) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("state", state);
+                json.put("task_id", taskId);
+                json.put("reason", reasonJson);
+                json.put("source", "system_server.openphone_agent");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
         private String actionResultJson(String state, String taskId, String inputJson,
                 String capability, String detail, String pendingActionId) {
             JSONObject json = new JSONObject();
@@ -818,6 +907,57 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             return json;
         }

+        private void recordPointerEvent(String taskId, String event, String detail) {
+            JSONObject json = new JSONObject();
+            try {
+                json.put("task_id", taskId);
+                json.put("event", event);
+                json.put("detail", detail);
+                json.put("timestamp_ms", System.currentTimeMillis());
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            synchronized (mPointerEventLock) {
+                while (mPointerEvents.size() >= MAX_AUDIT_EVENTS) {
+                    mPointerEvents.removeFirst();
+                }
+                mPointerEvents.addLast(json.toString());
+            }
+        }
+
+        private String pointerEventsJson(String taskId, int maxEvents) {
+            final JSONArray events = new JSONArray();
+            final int boundedMax = Math.max(1, Math.min(maxEvents, MAX_AUDIT_EVENTS));
+            synchronized (mPointerEventLock) {
+                final ArrayList<String> copy = new ArrayList<>(mPointerEvents);
+                final int start = Math.max(0, copy.size() - boundedMax);
+                for (int i = start; i < copy.size(); i++) {
+                    try {
+                        JSONObject event = new JSONObject(copy.get(i));
+                        if (taskId == null || taskId.equals(event.optString("task_id"))) {
+                            events.put(event);
+                        }
+                    } catch (JSONException ignored) {
+                    }
+                }
+            }
+            JSONObject json = new JSONObject();
+            try {
+                json.put("task_id", taskId);
+                json.put("events", events);
+                json.put("source", "system_server.openphone_agent");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private boolean isTaskActive(String taskId) {
+            synchronized (mTaskLock) {
+                return "active".equals(mTaskStates.get(taskId));
+            }
+        }
+
