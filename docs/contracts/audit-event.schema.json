{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.dev/schemas/audit-event.schema.json",
  "title": "OpenPhone Audit Event",
  "type": "object",
  "required": ["timestamp_elapsed_ms", "event_type"],
  "properties": {
    "timestamp_elapsed_ms": {
      "type": "integer"
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "event_type": {
      "enum": [
        "task_started",
        "task_stopped",
        "task_finished",
        "screen_context_read",
        "screen_capture",
        "screen_capture_rejected",
        "screen_watch_started",
        "screen_watch_rejected",
        "capability_evaluated",
        "action_rejected",
        "action_confirmed",
        "action_executed",
        "ui_tree_snapshot_submitted"
      ]
    },
    "capability": {
      "type": ["string", "null"]
    },
    "decision": {
      "type": ["string", "null"]
    },
    "caller_uid": {
      "type": "integer"
    },
    "detail": {
      "type": ["string", "null"]
    },
    "input_recorded": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
