From 1111111111111111111111111111111111111111 Mon Sep 17 00:00:00 2001
From: OpenPhone <openphone@example.invalid>
Date: Sun, 31 May 2026 11:23:00 +0000
Subject: [PATCH] OpenPhone: capture screenshots as system server

Change-Id: I4d9355cb7c65b732f4dd7c97867a3777f3d87e19
---
 .../openphone/OpenPhoneAgentManagerService.java  | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
index ccb60025e40d..31c0fd7acb68 100644
--- a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
+++ b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
@@ -687,7 +687,16 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             if (windowManager == null) {
                 return ScreenPayload.error("window_manager_unavailable");
             }
-            final ScreenshotHardwareBuffer hardwareBuffer = windowManager.takeAssistScreenshot();
+            final ScreenshotHardwareBuffer hardwareBuffer;
+            final long token = Binder.clearCallingIdentity();
+            try {
+                hardwareBuffer = windowManager.takeAssistScreenshot();
+            } catch (RuntimeException e) {
+                Slog.w(TAG, "OpenPhone screenshot capture failed", e);
+                return ScreenPayload.error("capture_exception:" + e.getClass().getSimpleName());
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
             if (hardwareBuffer == null || hardwareBuffer.getHardwareBuffer() == null) {
                 return ScreenPayload.error("capture_failed");
             }
--
