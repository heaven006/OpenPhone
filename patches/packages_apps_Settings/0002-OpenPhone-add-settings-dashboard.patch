From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenPhone <openphone@example.invalid>
Date: Mon, 1 Jun 2026 18:20:00 +0300
Subject: [PATCH] OpenPhone: add settings dashboard

Expose OpenPhone as a first-class Settings surface. The first page gives users
a normal OS-owned entry point for assistant controls, task grants, audit
evidence, and project support.
---
 res/values/strings.xml                         | 18 ++++++++++++++++++
 res/xml/openphone_settings.xml                 | 62 ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 res/xml/top_level_settings.xml                 | 10 ++++++++++
 .../settings/openphone/OpenPhoneSettings.java  | 46 ++++++++++++++++++++++++++++++++++++++++++++++
 4 files changed, 136 insertions(+)
 create mode 100644 res/xml/openphone_settings.xml
 create mode 100644 src/com/android/settings/openphone/OpenPhoneSettings.java

diff --git a/res/values/strings.xml b/res/values/strings.xml
--- a/res/values/strings.xml
+++ b/res/values/strings.xml
@@ -3617,6 +3617,24 @@
     <string name="openphone_support" translatable="false">OpenPhone support</string>
     <!-- About phone screen, OpenPhone support preference summary. -->
     <string name="openphone_support_summary" translatable="false">Build, flash, and issue reporting docs</string>
+    <!-- Settings homepage OpenPhone menu key. -->
+    <string name="menu_key_openphone" translatable="false">openphone</string>
+    <!-- Settings homepage OpenPhone title. -->
+    <string name="openphone_settings_title" translatable="false">OpenPhone</string>
+    <!-- Settings homepage OpenPhone summary. -->
+    <string name="openphone_settings_summary" translatable="false">AI assistant, task grants, and audit evidence</string>
+    <!-- OpenPhone settings assistant entry title. -->
+    <string name="openphone_assistant_title" translatable="false">Assistant</string>
+    <!-- OpenPhone settings assistant entry summary. -->
+    <string name="openphone_assistant_summary" translatable="false">Start tasks and review current assistant state</string>
+    <!-- OpenPhone settings task grants entry title. -->
+    <string name="openphone_task_grants_title" translatable="false">Task grants</string>
+    <!-- OpenPhone settings task grants entry summary. -->
+    <string name="openphone_task_grants_summary" translatable="false">Review input, screenshot, clipboard, sharing, and link permissions before a task runs</string>
+    <!-- OpenPhone settings audit entry title. -->
+    <string name="openphone_audit_title" translatable="false">Audit evidence</string>
+    <!-- OpenPhone settings audit entry summary. -->
+    <string name="openphone_audit_summary" translatable="false">Open audit export and trajectory evidence for assistant actions</string>
     <!-- About phone screen, status item label  [CHAR LIMIT=60] -->
     <string name="security_patch">Android security update</string>
     <!-- About phone screen, status item label  [CHAR LIMIT=40] -->
diff --git a/res/xml/openphone_settings.xml b/res/xml/openphone_settings.xml
new file mode 100644
--- /dev/null
+++ b/res/xml/openphone_settings.xml
@@ -0,0 +1,62 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!--
+  Copyright (C) 2026 The OpenPhone Project
+
+  Licensed under the Apache License, Version 2.0 (the "License");
+  you may not use this file except in compliance with the License.
+  You may obtain a copy of the License at
+
+       http://www.apache.org/licenses/LICENSE-2.0
+
+  Unless required by applicable law or agreed to in writing, software
+  distributed under the License is distributed on an "AS IS" BASIS,
+  WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+  See the License for the specific language governing permissions and
+  limitations under the License.
+  -->
+
+<PreferenceScreen
+    xmlns:android="http://schemas.android.com/apk/res/android"
+    android:key="openphone_settings"
+    android:title="@string/openphone_settings_title">
+
+    <Preference
+        android:key="openphone_assistant"
+        android:title="@string/openphone_assistant_title"
+        android:summary="@string/openphone_assistant_summary">
+        <intent
+            android:action="android.intent.action.MAIN"
+            android:targetPackage="org.openphone.assistant"
+            android:targetClass="org.openphone.assistant.MainActivity"/>
+    </Preference>
+
+    <Preference
+        android:key="openphone_task_grants"
+        android:title="@string/openphone_task_grants_title"
+        android:summary="@string/openphone_task_grants_summary">
+        <intent
+            android:action="android.intent.action.MAIN"
+            android:targetPackage="org.openphone.assistant"
+            android:targetClass="org.openphone.assistant.MainActivity"/>
+    </Preference>
+
+    <Preference
+        android:key="openphone_audit"
+        android:title="@string/openphone_audit_title"
+        android:summary="@string/openphone_audit_summary">
+        <intent
+            android:action="android.intent.action.MAIN"
+            android:targetPackage="org.openphone.assistant"
+            android:targetClass="org.openphone.assistant.MainActivity"/>
+    </Preference>
+
+    <Preference
+        android:key="openphone_support"
+        android:title="@string/openphone_support"
+        android:summary="@string/openphone_support_summary">
+        <intent
+            android:action="android.intent.action.VIEW"
+            android:data="https://github.com/secondly-com/OpenPhone"/>
+    </Preference>
+
+</PreferenceScreen>
diff --git a/res/xml/top_level_settings.xml b/res/xml/top_level_settings.xml
--- a/res/xml/top_level_settings.xml
+++ b/res/xml/top_level_settings.xml
@@ -140,6 +140,15 @@
             android:summary="@string/summary_placeholder"
             settings:highlightableMenuKey="@string/menu_key_about_device"
             settings:controller="com.android.settings.deviceinfo.aboutphone.TopLevelAboutDevicePreferenceController"/>
+
+        <com.android.settings.widget.HomepagePreference
+            android:fragment="com.android.settings.openphone.OpenPhoneSettings"
+            android:icon="@drawable/ic_settings_development"
+            android:key="top_level_openphone"
+            android:order="-5"
+            android:title="@string/openphone_settings_title"
+            android:summary="@string/openphone_settings_summary"
+            settings:highlightableMenuKey="@string/menu_key_openphone"/>
     </PreferenceCategory>
 
     <PreferenceCategory
diff --git a/src/com/android/settings/openphone/OpenPhoneSettings.java b/src/com/android/settings/openphone/OpenPhoneSettings.java
new file mode 100644
--- /dev/null
+++ b/src/com/android/settings/openphone/OpenPhoneSettings.java
@@ -0,0 +1,47 @@
