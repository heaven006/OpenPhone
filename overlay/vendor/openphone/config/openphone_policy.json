{
  "version": 1,
  "defaults": {
    "fail_closed": true,
    "audit_enabled": true,
    "store_sensitive_content": false
  },
  "risk_policy": {
    "low": {
      "confirmation": "task_grant",
      "audit": "metadata"
    },
    "medium": {
      "confirmation": "contextual",
      "audit": "metadata"
    },
    "high": {
      "confirmation": "explicit",
      "audit": "metadata"
    }
  }
}

