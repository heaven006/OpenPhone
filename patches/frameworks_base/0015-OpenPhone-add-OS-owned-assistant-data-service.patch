+        private String repairStuckLocked(SQLiteDatabase db, long staleBefore, long now) {
+            int repaired = 0;
+            final List<long[]> stuck = new ArrayList<>();
+            try (Cursor cursor = db.rawQuery("SELECT id, failure_count FROM watcher "
+                    + "WHERE status = 'active' AND deleted_at IS NULL "
+                    + "AND running_at > 0 AND running_at <= ? "
+                    + "ORDER BY running_at ASC LIMIT 50",
+                    new String[]{Long.toString(staleBefore)})) {
+                while (cursor.moveToNext()) {
+                    stuck.add(new long[]{cursor.getLong(0), cursor.getLong(1)});
+                }
+            }
+            for (long[] watcher : stuck) {
+                final long failures = watcher[1] + 1;
+                final ContentValues values = new ContentValues();
+                values.put("running_at", 0L);
+                values.put("updated_at", now);
+                values.put("next_run_at", now + backoffMillis((int) failures));
+                values.put("last_run_at", now);
+                values.put("failure_count", failures);
+                values.put("last_result_hash", "stuck_running_repaired");
+                if (failures >= 3) {
+                    values.put("failure_alert_at", now);
+                }
+                repaired += db.update("watcher", values, "id = ?",
+                        new String[]{Long.toString(watcher[0])});
+            }
+            try {
+                return new JSONObject().put("repaired", repaired).toString();
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+        }
