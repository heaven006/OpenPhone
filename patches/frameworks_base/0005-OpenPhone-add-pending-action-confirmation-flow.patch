From: OpenPhone <dev@openphone.local>
Date: Wed, 27 May 2026 02:12:49 +0300
Subject: [PATCH 5/7] OpenPhone: add pending action confirmation flow

Change-Id: I95f33e4bf9dc46e25d073df6590852fd3201e796

diff --git a/core/java/android/openphone/IOpenPhoneAgentService.aidl b/core/java/android/openphone/IOpenPhoneAgentService.aidl
index 58123b351f5e..5175c78d6d66 100644
--- a/core/java/android/openphone/IOpenPhoneAgentService.aidl
+++ b/core/java/android/openphone/IOpenPhoneAgentService.aidl
@@ -6,6 +6,7 @@ interface IOpenPhoneAgentService {
     String startTask(String taskRequestJson);
     String getScreenContext(String taskId);
     String executeAction(String taskId, String actionRequestJson);
+    String confirmAction(String pendingActionId, boolean approved);
     String evaluateCapability(String capabilityId);
     String getAuditLog(int maxEvents);
 }
diff --git a/core/java/android/openphone/OpenPhoneAgentManager.java b/core/java/android/openphone/OpenPhoneAgentManager.java
index ee08347ecf0b..aff9c157ba3c 100644
--- a/core/java/android/openphone/OpenPhoneAgentManager.java
+++ b/core/java/android/openphone/OpenPhoneAgentManager.java
@@ -75,6 +75,16 @@ public final class OpenPhoneAgentManager {
         }
     }
 
+    /** @hide */
+    @NonNull
+    public String confirmAction(@NonNull String pendingActionId, boolean approved) {
+        try {
+            return mService.confirmAction(pendingActionId, approved);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
     /** @hide */
     @NonNull
     public String evaluateCapability(@NonNull String capabilityId) {
diff --git a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
